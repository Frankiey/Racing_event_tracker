{
  "name": "racetrack",
  "version": "0.1.0",
  "description": "Motorsport event tracker — all races, one dashboard",
  "type": "module",
  "overrides": {
    "yaml-language-server": "1.22.0",
    "yaml": "2.8.3"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "fetch-data": "uv run python -m pipeline",
    "validate:data": "uv run python -m pipeline.validate",
    "typecheck": "astro check",
    "test": "astro check && npm run test:unit && npm run test:pipeline && node tests/smoke.test.mjs",
    "test:unit": "TZ=UTC node --experimental-strip-types --loader ./tests/unit/ts-loader.mjs --test tests/unit/*.test.mjs",
    "test:pipeline": "uv run python -m unittest discover -s tests -p 'test_*.py'",
    "test:smoke": "node tests/smoke.test.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "astro": "^6.4.2",
    "d3-drag": "^3.0.0",
    "d3-geo": "^3.1.1",
    "d3-interpolate": "^3.0.1",
    "d3-selection": "^3.0.0",
    "d3-timer": "^3.0.1",
    "topojson-client": "^3.1.0",
    "typescript": "6.0.3",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-timer": "^3.0.2",
    "@types/node": "^25.9.1",
    "@types/topojson-client": "^3.1.5",
    "tailwindcss": "^4.2.4",
    "vite": "^7.3.5"
  }
}
