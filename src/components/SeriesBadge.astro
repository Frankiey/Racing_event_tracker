---
import { getSeriesMeta } from '../lib/series';

interface Props {
  seriesId: string;
  size?: 'sm' | 'md' | 'lg';
}

const { seriesId, size = 'sm' } = Astro.props;
const meta = getSeriesMeta(seriesId);

const sizeClasses = size === 'sm'
  ? 'text-[10px] px-1.5 py-0.5'
  : size === 'lg'
    ? 'text-sm px-3 py-1 rounded-lg'
    : 'text-xs px-2 py-0.5';
---

<span
  class:list={['inline-block rounded font-bold uppercase tracking-wide text-white', sizeClasses]}
  style={`background-color: ${meta.color};`}
>
  {meta.shortLabel}
</span>
