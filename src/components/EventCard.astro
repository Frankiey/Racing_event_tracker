---
import SeriesBadge from './SeriesBadge.astro';
import { getSeriesMeta } from '../lib/series';
import { formatDateRange, getRaceSession, isPlaceholderTime } from '../lib/time';

interface Props {
  event: {
    id: string;
    seriesId: string;
    eventName: string;
    round: number;
    circuit: {
      name: string;
      city: string;
      country: string;
      countryCode: string;
    };
    sessions: { type: string; startTimeUTC: string }[];
    dateStart: string;
    dateEnd: string;
  };
  highlight?: boolean;
}

const { event, highlight = false } = Astro.props;
const meta = getSeriesMeta(event.seriesId);
const raceSession = getRaceSession(event.sessions);
const validSessions = event.sessions.filter(s => !isPlaceholderTime(s.startTimeUTC));
---

<article
  class:list={[
    'rounded-lg border p-4 transition-colors',
    highlight
      ? 'border-zinc-600 bg-zinc-800/80'
      : 'border-zinc-800 bg-zinc-900/60 hover:border-zinc-700',
  ]}
>
  <div class="flex items-start justify-between gap-3 mb-2">
    <div class="min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <SeriesBadge seriesId={event.seriesId} />
        <span class="text-xs text-zinc-500">R{event.round}</span>
      </div>
      <h3 class="font-semibold text-zinc-100 truncate">{event.eventName}</h3>
    </div>
    <div class="text-right shrink-0">
      <div class="text-sm font-medium text-zinc-300">
        {formatDateRange(event.dateStart, event.dateEnd)}
      </div>
    </div>
  </div>

  <div class="text-sm text-zinc-400 mb-3">
    {event.circuit.name}
    {event.circuit.city && ` · ${event.circuit.city}`}
    {event.circuit.country && `, ${event.circuit.country}`}
  </div>

  {validSessions.length > 0 && (
    <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-zinc-500">
      {validSessions.map(session => (
        <span class="flex items-center gap-1">
          <span class:list={[
            'w-1.5 h-1.5 rounded-full',
            (session.type === 'Race' || session.type === 'Feature Race')
              ? `bg-[${meta.color}]`
              : 'bg-zinc-600'
          ]}
          style={(session.type === 'Race' || session.type === 'Feature Race') ? `background-color: ${meta.color}` : ''}
          />
          <span>{session.type}</span>
          <time class="text-zinc-600 tabular-nums" data-utc={session.startTimeUTC}>
            {new Date(session.startTimeUTC).toLocaleDateString('en', { weekday: 'short' })}
          </time>
        </span>
      ))}
    </div>
  )}
</article>
