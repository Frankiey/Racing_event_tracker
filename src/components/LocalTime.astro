---
/**
 * Displays a UTC time, converting to local time in the browser.
 * Server-renders the UTC time, then client JS replaces it.
 */
interface Props {
  utc: string;
  format?: 'datetime' | 'time' | 'time-short' | 'date' | 'weekday-time';
}

const { utc, format = 'datetime' } = Astro.props;
import { formatUtcValue } from '../lib/time';
---

<time data-local-time={utc} data-format={format} datetime={utc} class="tabular-nums">
  {formatUtcValue(utc, format)}
</time>

<script>
  import { hydrateLocalTimes } from '../lib/ui/time-client';

  const initLocalTimes = () => hydrateLocalTimes();

  initLocalTimes();
  document.addEventListener('astro:after-swap', initLocalTimes);
</script>
