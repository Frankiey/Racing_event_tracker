---
import { SERIES_LIST } from '../lib/series';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav id="main-nav" class="border-b border-zinc-800/80 bg-zinc-950/90 backdrop-blur-md sticky top-0 z-50 mt-[3px]">
  <div class="max-w-5xl mx-auto px-4 flex items-center h-12 gap-1">

    <!-- Wordmark -->
    <a href={`${base}/`} class="flex items-center gap-2 font-black text-sm tracking-tight text-zinc-100 shrink-0 mr-4">
      <span class="text-base">🏁</span>
      <span>RACETRACK</span>
    </a>

    <!-- Desktop primary links (md+) -->
    <div class="hidden md:flex items-center gap-1 text-sm flex-1">
      {[
        { href: `${base}/`, label: 'Dashboard' },
        { href: `${base}/calendar`, label: 'Calendar' },
      ].map(link => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-1.5 rounded-lg transition-colors font-medium text-sm',
            currentPath === link.href
              ? 'bg-zinc-800 text-zinc-100'
              : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900'
          ]}
        >
          {link.label}
        </a>
      ))}

      <!-- Series dropdown (hover, desktop only) -->
      <div class="relative group">
        <button class:list={[
          'px-3 py-1.5 rounded-lg transition-colors font-medium text-sm flex items-center gap-1.5',
          currentPath.startsWith(`${base}/series`)
            ? 'bg-zinc-800 text-zinc-100'
            : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900'
        ]}>
          Series
          <svg class="w-3 h-3 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute top-full left-0 mt-1 py-1.5 bg-zinc-900 border border-zinc-700/60 rounded-xl shadow-2xl shadow-black/60 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 min-w-[152px] z-50">
          {SERIES_LIST.map(s => (
            <a
              href={`${base}/series/${s.id}`}
              class:list={[
                'flex items-center gap-2.5 px-3 py-2 text-xs font-medium hover:bg-zinc-800 transition-colors',
                currentPath === `${base}/series/${s.id}` ? 'text-zinc-100' : 'text-zinc-300'
              ]}
            >
              <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${s.color}`} />
              {s.label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Desktop: Watchlist + Kiosk -->
    <div class="hidden md:flex items-center gap-1">
      <a
        href={`${base}/watchlist`}
        class:list={[
          'flex items-center gap-1.5 px-3 py-1.5 rounded-lg transition-colors text-sm font-medium shrink-0',
          currentPath === `${base}/watchlist`
            ? 'bg-zinc-800 text-rose-400'
            : 'text-zinc-500 hover:text-zinc-200 hover:bg-zinc-900'
        ]}
      >
        <svg class="w-4 h-4" fill={currentPath === `${base}/watchlist` ? '#f43f5e' : 'none'} viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
        <span>Watchlist</span>
        <span id="nav-fav-count" class="hidden text-[10px] font-bold bg-rose-500/20 text-rose-400 px-1.5 rounded-full" />
      </a>

      <a
        href={`${base}/status`}
        title="Kiosk / ambient display"
        class="kiosk-nav-btn relative flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg border border-red-900/50 bg-red-950/20 text-red-400 text-[11px] font-bold uppercase tracking-widest hover:bg-red-950/50 hover:border-red-600/70 hover:text-red-300 transition-all duration-200 shrink-0 ml-2 group"
      >
        <span class="relative flex h-1.5 w-1.5 shrink-0">
          <span class="kiosk-nav-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-60"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-red-500 group-hover:bg-red-400 transition-colors"></span>
        </span>
        <svg class="w-3.5 h-3.5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2" stroke-linecap="round"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 21h8M12 17v4"/>
        </svg>
        <span>Kiosk</span>
      </a>
    </div>

    <!-- Mobile right: watchlist icon + hamburger -->
    <div class="flex md:hidden items-center gap-1 ml-auto">
      <a
        href={`${base}/watchlist`}
        class:list={[
          'flex items-center gap-1 p-2 rounded-lg transition-colors',
          currentPath === `${base}/watchlist` ? 'text-rose-400' : 'text-zinc-500 hover:text-zinc-200'
        ]}
        aria-label="Watchlist"
      >
        <svg class="w-5 h-5" fill={currentPath === `${base}/watchlist` ? '#f43f5e' : 'none'} viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
        <span id="nav-fav-count-mobile" class="hidden text-[10px] font-bold bg-rose-500/20 text-rose-400 px-1 rounded-full" />
      </a>

      <button
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        class="p-2 rounded-lg text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900 transition-colors"
      >
        <svg id="hamburger-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-zinc-800/50 bg-zinc-950 overflow-y-auto max-h-[calc(100vh-3rem)]"
  >
    <div class="max-w-5xl mx-auto px-4 py-3">
      <!-- Primary links -->
      <div class="space-y-0.5 mb-3">
        {[
          { href: `${base}/`, label: 'Dashboard' },
          { href: `${base}/calendar`, label: 'Calendar' },
          { href: `${base}/watchlist`, label: 'Watchlist' },
        ].map(link => (
          <a
            href={link.href}
            class:list={[
              'flex items-center px-3 py-2.5 rounded-lg transition-colors font-medium text-sm',
              currentPath === link.href
                ? 'bg-zinc-800 text-zinc-100'
                : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900'
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href={`${base}/status`}
          class:list={[
            'flex items-center gap-2 px-3 py-2.5 rounded-lg transition-colors font-medium text-sm',
            currentPath === `${base}/status`
              ? 'bg-zinc-800 text-red-400'
              : 'text-red-500/70 hover:text-red-400 hover:bg-zinc-900'
          ]}
        >
          <span class="relative flex h-1.5 w-1.5">
            <span class="kiosk-nav-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-60"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-red-500"></span>
          </span>
          Kiosk
        </a>
      </div>

      <!-- Series grid -->
      <div class="border-t border-zinc-800/50 pt-3">
        <p class="text-[10px] uppercase tracking-widest text-zinc-600 font-bold px-3 mb-2">Series</p>
        <div class="grid grid-cols-2 gap-0.5">
          {SERIES_LIST.map(s => (
            <a
              href={`${base}/series/${s.id}`}
              class:list={[
                'flex items-center gap-2 px-3 py-2 rounded-lg text-xs font-medium transition-colors',
                currentPath === `${base}/series/${s.id}`
                  ? 'bg-zinc-800 text-zinc-100'
                  : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900'
              ]}
            >
              <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${s.color}`} />
              {s.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  function updateNavFavCount() {
    const favs: string[] = (JSON.parse(localStorage.getItem('rt-favs') ?? '[]') as unknown[]).filter(Boolean) as string[];

    // Desktop badge
    const badge = document.getElementById('nav-fav-count');
    if (badge) {
      if (favs.length > 0) {
        badge.textContent = String(favs.length);
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    }

    // Mobile badge
    const mobileBadge = document.getElementById('nav-fav-count-mobile');
    if (mobileBadge) {
      if (favs.length > 0) {
        mobileBadge.textContent = String(favs.length);
        mobileBadge.classList.remove('hidden');
      } else {
        mobileBadge.classList.add('hidden');
      }
    }
  }

  function initMobileNav() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const hamburger = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!btn || !menu) return;

    function openMenu() {
      menu!.classList.remove('hidden');
      hamburger!.classList.add('hidden');
      closeIcon!.classList.remove('hidden');
      btn!.setAttribute('aria-expanded', 'true');
    }

    function closeMenu() {
      menu!.classList.add('hidden');
      hamburger!.classList.remove('hidden');
      closeIcon!.classList.add('hidden');
      btn!.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !menu.classList.contains('hidden');
      isOpen ? closeMenu() : openMenu();
    });

    // Close when a link inside the menu is tapped
    menu.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) closeMenu();
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!document.getElementById('main-nav')?.contains(e.target as Node)) {
        closeMenu();
      }
    });
  }

  updateNavFavCount();
  initMobileNav();

  window.addEventListener('rt-favs-changed', updateNavFavCount);
  document.addEventListener('astro:after-swap', () => {
    updateNavFavCount();
    initMobileNav();
  });
</script>
