---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const links = [
  { href: `${base}/`, label: 'Dashboard' },
  { href: `${base}/calendar`, label: 'Calendar' },
];
---

<nav class="border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 flex items-center h-12 gap-6">
    <a href={`${base}/`} class="font-bold text-lg tracking-tight text-zinc-100">
      RaceTrack
    </a>
    <div class="flex gap-4 text-sm">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'transition-colors',
            currentPath === link.href
              ? 'text-zinc-100 font-medium'
              : 'text-zinc-400 hover:text-zinc-200'
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>
