---
import { SERIES_LIST } from '../lib/series';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<nav class="border-b border-zinc-800/80 bg-zinc-950/90 backdrop-blur-md sticky top-0 z-50 mt-[3px]">
  <div class="max-w-5xl mx-auto px-4 flex items-center h-12 gap-1">

    <!-- Wordmark -->
    <a href={`${base}/`} class="flex items-center gap-2 font-black text-sm tracking-tight text-zinc-100 shrink-0 mr-4">
      <span class="text-base">🏁</span>
      <span>RACETRACK</span>
    </a>

    <!-- Primary links -->
    <div class="flex items-center gap-1 text-sm flex-1">
      {[
        { href: `${base}/`, label: 'Dashboard' },
        { href: `${base}/calendar`, label: 'Calendar' },
      ].map(link => (
        <a
          href={link.href}
          class:list={[
            'px-3 py-1.5 rounded-lg transition-colors font-medium text-sm',
            currentPath === link.href
              ? 'bg-zinc-800 text-zinc-100'
              : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900'
          ]}
        >
          {link.label}
        </a>
      ))}

      <!-- Series dropdown -->
      <div class="relative group" id="series-dropdown-group">
        <button
          id="series-dropdown-btn"
          aria-haspopup="true"
          aria-expanded="false"
          class:list={[
            'px-3 py-1.5 rounded-lg transition-colors font-medium text-sm flex items-center gap-1.5',
            currentPath.startsWith(`${base}/series`)
              ? 'bg-zinc-800 text-zinc-100'
              : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-900'
          ]}
        >
          Series
          <svg class="w-3 h-3 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div
          id="series-dropdown-menu"
          class="absolute top-full left-0 mt-1 py-1.5 bg-zinc-900 border border-zinc-700/60 rounded-xl shadow-2xl shadow-black/60 opacity-0 invisible transition-all duration-150 min-w-[152px] z-50"
        >
          {SERIES_LIST.map(s => (
            <a
              href={`${base}/series/${s.id}`}
              class:list={[
                'flex items-center gap-2.5 px-3 py-2 text-xs font-medium hover:bg-zinc-800 transition-colors',
                currentPath === `${base}/series/${s.id}` ? 'text-zinc-100' : 'text-zinc-300'
              ]}
            >
              <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${s.color}`} />
              {s.label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Watchlist -->
    <a
      href={`${base}/watchlist`}
      class:list={[
        'flex items-center gap-1.5 px-3 py-1.5 rounded-lg transition-colors text-sm font-medium shrink-0',
        currentPath === `${base}/watchlist`
          ? 'bg-zinc-800 text-rose-400'
          : 'text-zinc-500 hover:text-zinc-200 hover:bg-zinc-900'
      ]}
    >
      <svg class="w-4 h-4" fill={currentPath === `${base}/watchlist` ? '#f43f5e' : 'none'} viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
      </svg>
      <span class="hidden sm:inline">Watchlist</span>
      <span id="nav-fav-count" class="hidden text-[10px] font-bold bg-rose-500/20 text-rose-400 px-1.5 rounded-full" />
    </a>

    <!-- Status kiosk link -->
    <a href={`${base}/status`} class="text-[10px] text-zinc-700 hover:text-zinc-500 transition-colors shrink-0 font-mono uppercase tracking-widest ml-1">
      Kiosk
    </a>
  </div>
</nav>

<script>
  function updateNavFavCount() {
    const favs: string[] = (JSON.parse(localStorage.getItem('rt-favs') ?? '[]') as unknown[]).filter(Boolean) as string[];
    const badge = document.getElementById('nav-fav-count');
    if (!badge) return;
    if (favs.length > 0) {
      badge.textContent = String(favs.length);
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  }
  updateNavFavCount();
  window.addEventListener('rt-favs-changed', updateNavFavCount);
  document.addEventListener('astro:after-swap', updateNavFavCount);

  function initSeriesDropdown() {
    const btn = document.getElementById('series-dropdown-btn');
    const menu = document.getElementById('series-dropdown-menu');
    const group = document.getElementById('series-dropdown-group');
    if (!btn || !menu || !group) return;

    function open() {
      menu.classList.remove('opacity-0', 'invisible');
      menu.classList.add('opacity-100', 'visible');
      btn.setAttribute('aria-expanded', 'true');
    }
    function close() {
      menu.classList.add('opacity-0', 'invisible');
      menu.classList.remove('opacity-100', 'visible');
      btn.setAttribute('aria-expanded', 'false');
    }
    function isOpen() {
      return !menu.classList.contains('invisible');
    }

    // Desktop hover
    group.addEventListener('mouseenter', open);
    group.addEventListener('mouseleave', close);

    // Mobile tap: toggle on button click
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      isOpen() ? close() : open();
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!group.contains(e.target as Node)) close();
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }

  initSeriesDropdown();
  document.addEventListener('astro:after-swap', initSeriesDropdown);
</script>
