---
/**
 * Countdown timer to next race session.
 * Renders server-side with a placeholder, then hydrates client-side.
 */
interface Props {
  targetUTC: string;
  label: string;
}

const { targetUTC, label } = Astro.props;
---

<div class="text-center" data-countdown={targetUTC}>
  <p class="text-xs text-zinc-500 uppercase tracking-wide mb-1">{label}</p>
  <div class="flex items-center justify-center gap-3 text-2xl font-mono font-bold text-zinc-100">
    <div class="flex flex-col items-center">
      <span data-unit="days" class="tabular-nums">--</span>
      <span class="text-[10px] text-zinc-500 font-sans font-normal">days</span>
    </div>
    <span class="text-zinc-600">:</span>
    <div class="flex flex-col items-center">
      <span data-unit="hours" class="tabular-nums">--</span>
      <span class="text-[10px] text-zinc-500 font-sans font-normal">hrs</span>
    </div>
    <span class="text-zinc-600">:</span>
    <div class="flex flex-col items-center">
      <span data-unit="minutes" class="tabular-nums">--</span>
      <span class="text-[10px] text-zinc-500 font-sans font-normal">min</span>
    </div>
    <span class="text-zinc-600">:</span>
    <div class="flex flex-col items-center">
      <span data-unit="seconds" class="tabular-nums">--</span>
      <span class="text-[10px] text-zinc-500 font-sans font-normal">sec</span>
    </div>
  </div>
</div>

<script>
  import { cleanupCountdowns, initCountdowns } from '../lib/ui/countdown';

  const initCountdownNodes = () => initCountdowns();
  const cleanupCountdownNodes = () => cleanupCountdowns();

  // Run on initial load and after Astro page transitions
  initCountdownNodes();
  document.addEventListener('astro:before-swap', cleanupCountdownNodes);
  document.addEventListener('astro:after-swap', initCountdownNodes);
</script>
