---
/**
 * Global event detail modal.
 * Opens when any EventCard emits 'rt-open-event'.
 * Shows full session schedule, circuit info, and favorite toggle.
 */
import WeekendTimeline from './WeekendTimeline.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!-- Overlay -->
<div
  id="event-modal"
  data-base={base}
  class="fixed inset-0 z-[200] flex items-end sm:items-center justify-center p-4"
  aria-modal="true"
  role="dialog"
  aria-labelledby="modal-title"
>
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm" />

  <!-- Panel -->
  <div
    id="modal-panel"
    class="relative w-full max-w-lg rounded-2xl border border-zinc-700/60 bg-zinc-950 shadow-2xl overflow-hidden"
  >
    <!-- Series color bar -->
    <div id="modal-color-bar" class="h-1 w-full" />

    <!-- Header -->
    <div class="p-6 pb-0">
      <div class="flex items-start justify-between gap-4 mb-1">
        <div class="flex items-center gap-2 flex-wrap">
          <span id="modal-badge" class="inline-block rounded font-bold uppercase tracking-wide text-white text-xs px-2 py-0.5" />
          <span id="modal-round" class="text-xs text-zinc-500 font-mono" />
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <!-- Share -->
          <button
            id="modal-share-btn"
            class="p-2 rounded-full hover:bg-zinc-800 transition-colors text-zinc-400 hover:text-zinc-200"
            aria-label="Share event"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" />
            </svg>
          </button>
          <!-- Favorite -->
          <button
            id="modal-fav-btn"
            class="modal-fav-btn p-2 rounded-full hover:bg-zinc-800 transition-colors"
            data-fav="false"
            aria-label="Add to favorites"
          >
            <svg class="w-5 h-5 stroke-zinc-400 fill-none" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </button>
          <!-- Close -->
          <button
            id="modal-close"
            class="p-2 rounded-full hover:bg-zinc-800 transition-colors text-zinc-400 hover:text-zinc-200"
            aria-label="Close"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <h2 id="modal-title" class="text-2xl font-black text-zinc-100 tracking-tight leading-tight mb-1" />
      <div id="modal-circuit" class="flex items-center gap-1.5 text-sm text-zinc-400 mb-4" />
    </div>

    <!-- Sessions -->
    <div class="px-6 pb-2">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">Session Schedule</h3>
        <div class="flex rounded-md overflow-hidden border border-zinc-700/60">
          <button id="view-list-btn" class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-zinc-700 text-zinc-200" aria-pressed="true">
            List
          </button>
          <button id="view-timeline-btn" class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-zinc-500 hover:text-zinc-300" aria-pressed="false">
            Timeline
          </button>
        </div>
      </div>
      <div id="modal-sessions" class="space-y-1.5" />
      <WeekendTimeline />
    </div>

    <!-- Footer actions -->
    <div class="px-6 py-4 mt-2 border-t border-zinc-800/60 flex items-center justify-between gap-3">
      <a
        id="modal-series-link"
        href="#"
        class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors"
      >
        View full series schedule →
      </a>
      <span id="modal-status-badge" class="text-xs px-2 py-1 rounded-full font-semibold" />
    </div>
  </div>
</div>

<!-- Share toast — fixed, above the modal -->
<div
  id="modal-share-toast"
  class="fixed top-4 left-1/2 -translate-x-1/2 hidden bg-zinc-800 border border-zinc-700 text-zinc-100 text-xs font-semibold px-4 py-2 rounded-full shadow-xl z-[300] pointer-events-none"
>
  Link copied!
</div>

<script>
  import { SESSION_LABELS } from '../lib/sessions';
  import { SERIES_META } from '../lib/series-client';

  // ── Series metadata (imported from series-client.ts) ──

  const PLACEHOLDER_YEAR = '1900';

  function isPlaceholder(utc: string) { return utc.startsWith(PLACEHOLDER_YEAR); }
  function isRaceType(type: string) { return type === 'Race' || type === 'Feature Race'; }

  function localDatetime(utc: string) {
    const d = new Date(utc);
    const date = d.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric' });
    const time = d.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit', hour12: false });
    return `${date} · ${time}`;
  }

  function countryFlag(code: string) {
    if (!code || code.length !== 2) return '';
    const base = 0x1F1E6 - 0x41;
    return String.fromCodePoint(code.toUpperCase().charCodeAt(0) + base, code.toUpperCase().charCodeAt(1) + base);
  }

  const modal = document.getElementById('event-modal')!;
  const panel = document.getElementById('modal-panel')!;

  function openModal(event: any) {
    const meta = SERIES_META[event.seriesId] ?? { label: event.seriesId, shortLabel: event.seriesId, color: '#71717a' };
    const base = (document.getElementById('event-modal')!.dataset.base ?? '');
    const favs: Set<string> = new Set(JSON.parse(localStorage.getItem('rt-favs') ?? '[]'));
    const isFav = favs.has(event.id);
    const isPast = new Date(event.dateEnd + 'T23:59:59Z') < new Date();

    // Color bar
    (document.getElementById('modal-color-bar') as HTMLElement).style.background = meta.color;

    // Badge
    const badge = document.getElementById('modal-badge') as HTMLElement;
    badge.textContent = meta.shortLabel;
    badge.style.backgroundColor = meta.color;

    // Round
    (document.getElementById('modal-round') as HTMLElement).textContent = `Round ${event.round}`;

    // Title
    (document.getElementById('modal-title') as HTMLElement).textContent = event.eventName;

    // Circuit
    const circuitEl = document.getElementById('modal-circuit') as HTMLElement;
    const flag = countryFlag(event.circuit.countryCode);
    circuitEl.innerHTML = `
      ${flag ? `<span class="text-lg">${flag}</span>` : ''}
      <span class="font-medium text-zinc-300">${event.circuit.name}</span>
      ${event.circuit.city ? `<span class="text-zinc-600">·</span><span>${event.circuit.city}</span>` : ''}
      ${event.circuit.country ? `<span class="text-zinc-600">·</span><span>${event.circuit.country}</span>` : ''}
    `;

    // Sessions
    const sessionsEl = document.getElementById('modal-sessions') as HTMLElement;
    const validSessions = (event.sessions as { type: string; startTimeUTC: string }[]).filter((s) => !isPlaceholder(s.startTimeUTC));
    sessionsEl.innerHTML = validSessions.map((s: any) => {
      const isRace = isRaceType(s.type);
      const isPastSession = new Date(s.startTimeUTC) < new Date();
      const isNext = !isPastSession && validSessions.filter((x: any) => new Date(x.startTimeUTC) < new Date()).length === validSessions.indexOf(s);
      const label = SESSION_LABELS[s.type] ?? s.type;
      const dotColor = isRace ? meta.color : isPastSession ? '#27272a' : '#52525b';

      return `
        <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg ${isPastSession ? 'opacity-40' : isNext ? 'bg-zinc-800/80 ring-1 ring-zinc-700' : 'hover:bg-zinc-900'}">
          <span class="w-2 h-2 rounded-full shrink-0" style="background-color:${dotColor}"></span>
          <span class="flex-1 text-sm font-semibold ${isRace ? 'text-zinc-100' : isPastSession ? 'text-zinc-600' : 'text-zinc-300'}">${label}</span>
          <time class="text-sm tabular-nums font-mono ${isPastSession ? 'text-zinc-700' : isRace ? 'text-zinc-200' : 'text-zinc-400'}" title="${s.startTimeUTC}">
            ${localDatetime(s.startTimeUTC)}
          </time>
          ${isPastSession ? '<span class="text-[10px] text-zinc-700 font-semibold uppercase tracking-wide ml-2">Done</span>' : ''}
        </div>
      `;
    }).join('');

    // Series link
    const link = document.getElementById('modal-series-link') as HTMLAnchorElement;
    link.href = `${base}/series/${event.seriesId}`;
    link.textContent = `View full ${meta.label} schedule →`;

    // Status badge
    const statusBadge = document.getElementById('modal-status-badge') as HTMLElement;
    if (isPast) {
      statusBadge.textContent = 'Completed';
      statusBadge.className = 'text-xs px-2 py-1 rounded-full font-semibold bg-zinc-800 text-zinc-500';
    } else {
      statusBadge.textContent = 'Upcoming';
      statusBadge.className = 'text-xs px-2 py-1 rounded-full font-semibold';
      statusBadge.style.backgroundColor = meta.color + '20';
      statusBadge.style.color = meta.color;
    }

    // Favorite button (class modal-fav-btn — intentionally different from .fav-btn on cards)
    const favBtn = document.getElementById('modal-fav-btn') as HTMLButtonElement;
    favBtn.dataset.fav = isFav ? 'true' : 'false';
    favBtn.onclick = () => {
      const favs: Set<string> = new Set(JSON.parse(localStorage.getItem('rt-favs') ?? '[]'));
      if (favs.has(event.id)) { favs.delete(event.id); favBtn.dataset.fav = 'false'; }
      else                    { favs.add(event.id);    favBtn.dataset.fav = 'true'; }
      localStorage.setItem('rt-favs', JSON.stringify([...favs]));
      window.dispatchEvent(new CustomEvent('rt-favs-changed'));
    };

    // Reset to list view when opening modal
    showListView();

    // Render timeline (lazy — only when switched to)
    currentEvent = event;

    // Deeplink: reflect this event in URL
    const dlUrl = new URL(window.location.href);
    dlUrl.searchParams.set('event', event.id);
    history.replaceState(null, '', dlUrl.toString());

    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('open');
    document.body.style.overflow = '';
    // Remove event from URL
    const dlUrl = new URL(window.location.href);
    dlUrl.searchParams.delete('event');
    history.replaceState(null, '', dlUrl.toString());
  }

  // ── View toggle ──
  let currentEvent: any = null;
  const sessionsEl = document.getElementById('modal-sessions')!;
  const timelineEl = document.getElementById('weekend-timeline')!;
  const listBtn = document.getElementById('view-list-btn')!;
  const tlBtn = document.getElementById('view-timeline-btn')!;

  function showListView() {
    sessionsEl.classList.remove('hidden');
    timelineEl.classList.add('hidden');
    listBtn.classList.add('bg-zinc-700', 'text-zinc-200');
    listBtn.classList.remove('text-zinc-500');
    listBtn.setAttribute('aria-pressed', 'true');
    tlBtn.classList.remove('bg-zinc-700', 'text-zinc-200');
    tlBtn.classList.add('text-zinc-500');
    tlBtn.setAttribute('aria-pressed', 'false');
  }

  function showTimelineView() {
    sessionsEl.classList.add('hidden');
    timelineEl.classList.remove('hidden');
    tlBtn.classList.add('bg-zinc-700', 'text-zinc-200');
    tlBtn.classList.remove('text-zinc-500');
    tlBtn.setAttribute('aria-pressed', 'true');
    listBtn.classList.remove('bg-zinc-700', 'text-zinc-200');
    listBtn.classList.add('text-zinc-500');
    listBtn.setAttribute('aria-pressed', 'false');
    if (currentEvent && (window as any).__renderTimeline) {
      (window as any).__renderTimeline(currentEvent);
    }
  }

  listBtn.addEventListener('click', showListView);
  tlBtn.addEventListener('click', showTimelineView);

  document.getElementById('modal-close')!.addEventListener('click', closeModal);
  document.getElementById('modal-backdrop')!.addEventListener('click', closeModal);
  window.addEventListener('rt-open-event', (e: Event) => openModal((e as CustomEvent).detail));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  document.addEventListener('astro:before-swap', () => { document.body.style.overflow = ''; });

  // ── Share button ──
  const shareBtn = document.getElementById('modal-share-btn')!;
  const shareToast = document.getElementById('modal-share-toast')!;
  let shareToastTimer: ReturnType<typeof setTimeout> | null = null;

  shareBtn.addEventListener('click', async () => {
    if (!currentEvent) return;
    const shareUrl = new URL(window.location.href);
    shareUrl.searchParams.set('event', currentEvent.id);
    const url = shareUrl.toString();
    if (typeof navigator.share === 'function') {
      try {
        await navigator.share({ title: currentEvent.eventName, url });
        return;
      } catch (err) {
        if ((err as Error).name === 'AbortError') return;
      }
    }
    try { await navigator.clipboard.writeText(url); } catch {}
    shareToast.classList.remove('hidden');
    if (shareToastTimer) clearTimeout(shareToastTimer);
    shareToastTimer = setTimeout(() => shareToast.classList.add('hidden'), 2000);
  });

  // ── Deeplink: open event from ?event= param on page load ──
  (function resolveDeeplink() {
    const eventId = new URLSearchParams(window.location.search).get('event');
    if (!eventId) return;
    // 1. Try EventCard DOM elements (index/calendar pages)
    const el = document.querySelector(`[data-event-id="${CSS.escape(eventId)}"]`);
    if (el) {
      try {
        const ev = JSON.parse((el as HTMLElement).getAttribute('data-event') ?? '');
        if (ev?.id) { openModal(ev); return; }
      } catch {}
    }
    // 2. Try page-registered event list (__rtAllEvents or __passportFullEvents)
    const all: any[] | undefined = (window as any).__rtAllEvents ?? (window as any).__passportFullEvents;
    if (all) {
      const ev = all.find((e: any) => e.id === eventId);
      if (ev) openModal(ev);
    }
  })();
</script>
