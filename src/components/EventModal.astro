---
/**
 * Global event detail modal.
 * Opens when any EventCard emits 'rt-open-event'.
 * Shows full session schedule, circuit info, and favorite toggle.
 */
import WeekendTimeline from './WeekendTimeline.astro';
import broadcastData from '../../data/gold/broadcasts.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<script id="broadcast-data" type="application/json" set:html={JSON.stringify(broadcastData)} />

<!-- Overlay -->
<div
  id="event-modal"
  data-base={base}
  class="fixed inset-0 z-[200] flex items-end sm:items-center justify-center p-4 overflow-y-auto"
  aria-modal="true"
  role="dialog"
  aria-labelledby="modal-title"
>
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm" />

  <!-- Panel -->
  <div
    id="modal-panel"
    class="relative w-full max-w-lg rounded-2xl border border-zinc-700/60 bg-zinc-950 shadow-2xl max-h-[90vh] overflow-y-auto overscroll-contain touch-pan-y"
  >
    <!-- Series color bar -->
    <div id="modal-color-bar" class="h-1 w-full shrink-0" />

    <!-- Header -->
    <div class="p-6 pb-0 shrink-0">
      <div class="flex items-start justify-between gap-4 mb-1">
        <div class="flex items-center gap-2 flex-wrap">
          <span id="modal-badge" class="inline-block rounded font-bold uppercase tracking-wide text-white text-xs px-2 py-0.5" />
          <span id="modal-round" class="text-xs text-zinc-500 font-mono" />
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <!-- Share -->
          <button
            id="modal-share-btn"
            class="p-2 rounded-full hover:bg-zinc-800 transition-colors text-zinc-400 hover:text-zinc-200"
            aria-label="Share event"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" />
            </svg>
          </button>
          <!-- Favorite -->
          <button
            id="modal-fav-btn"
            class="modal-fav-btn p-2 rounded-full hover:bg-zinc-800 transition-colors"
            data-fav="false"
            aria-label="Add to favorites"
          >
            <svg class="w-5 h-5 stroke-zinc-400 fill-none" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </button>
          <!-- Close -->
          <button
            id="modal-close"
            class="p-2 rounded-full hover:bg-zinc-800 transition-colors text-zinc-400 hover:text-zinc-200"
            aria-label="Close"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <h2 id="modal-title" class="text-2xl font-black text-zinc-100 tracking-tight leading-tight mb-1" />
      <div id="modal-circuit" class="flex items-center gap-1.5 text-sm text-zinc-400 mb-4" />
    </div>

    <!-- Sessions -->
    <div class="px-6 pb-2">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">Session Schedule</h3>
        <div class="flex rounded-md overflow-hidden border border-zinc-700/60">
          <button id="view-list-btn" class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-zinc-700 text-zinc-200" aria-pressed="true">
            List
          </button>
          <button id="view-timeline-btn" class="px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-zinc-500 hover:text-zinc-300" aria-pressed="false">
            Timeline
          </button>
        </div>
      </div>
      <div id="modal-sessions" class="space-y-1.5" />
      <WeekendTimeline />
    </div>

    <!-- Where to watch -->
    <div id="modal-broadcast" class="px-6 pb-2 hidden">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">Where to Watch</h3>
        <select id="broadcast-region" class="text-[10px] bg-zinc-800 border border-zinc-700 rounded px-2 py-0.5 text-zinc-300 cursor-pointer">
          <option value="NL">🇳🇱 NL</option>
          <option value="US">🇺🇸 US</option>
          <option value="UK">🇬🇧 UK</option>
        </select>
      </div>
      <div id="broadcast-list" class="space-y-1.5" />
    </div>

    <!-- Session alert -->
    <div id="modal-alert" class="px-6 pb-2 hidden">
      <div class="flex items-center gap-2 p-3 rounded-lg bg-zinc-900/80 border border-zinc-800/60">
        <svg class="w-4 h-4 text-zinc-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
        </svg>
        <span class="text-xs text-zinc-400 flex-1">Remind me before the race</span>
        <select id="alert-offset" class="text-[10px] bg-zinc-800 border border-zinc-700 rounded px-2 py-0.5 text-zinc-300 cursor-pointer">
          <option value="15">15 min</option>
          <option value="30" selected>30 min</option>
          <option value="60">1 hour</option>
        </select>
        <button id="alert-set-btn" class="text-[10px] font-bold uppercase tracking-wide px-2.5 py-1 rounded bg-zinc-700 hover:bg-zinc-600 text-zinc-200 transition-colors">
          Set
        </button>
      </div>
      <div id="alert-status" class="text-[10px] text-zinc-600 mt-1 px-1 hidden" />
    </div>

    <!-- Footer actions -->
    <div class="px-6 py-4 border-t border-zinc-800/60 flex items-center justify-between gap-3 shrink-0">
      <a
        id="modal-series-link"
        href="#"
        class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors"
      >
        View full series schedule →
      </a>
      <div class="flex items-center gap-2">
        <button
          id="modal-ics-btn"
          class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors flex items-center gap-1"
          aria-label="Add to calendar"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
          </svg>
          .ics
        </button>
        <span id="modal-status-badge" class="text-xs px-2 py-1 rounded-full font-semibold" />
      </div>
    </div>
  </div>
</div>

<!-- Share toast — fixed, above the modal -->
<div
  id="modal-share-toast"
  class="fixed top-4 left-1/2 -translate-x-1/2 hidden bg-zinc-800 border border-zinc-700 text-zinc-100 text-xs font-semibold px-4 py-2 rounded-full shadow-xl z-[300] pointer-events-none"
>
  Link copied!
</div>

<script>
  import { SESSION_LABELS } from '../lib/sessions';
  import { getClientSeriesMeta } from '../lib/series-client';
  import { countryFlag, formatLocalDatetime, isPlaceholderTime, isPastEvent, readFavorites, toggleFavorite, sleepVerdict, isSessionLive } from '../lib/client-utils';
  import { exportEventIcs } from '../lib/ics';
  import type { RaceEvent } from '../lib/types';

  interface BroadcastChannel {
    channel: string;
    type: string;
    note?: string;
  }

  // ── Broadcast data ──
  const _bdRaw = document.getElementById('broadcast-data')?.textContent ?? '{}';
  const broadcastDb: { series?: Record<string, Record<string, { channel: string; type: string; note?: string }[]>> } = JSON.parse(_bdRaw);
  const broadcastSection = document.getElementById('modal-broadcast')!;
  const broadcastList = document.getElementById('broadcast-list')!;
  const regionSelect = document.getElementById('broadcast-region') as HTMLSelectElement;

  // Restore saved region preference
  const savedRegion = localStorage.getItem('rt-broadcast-region');
  if (savedRegion && ['NL', 'US', 'UK'].includes(savedRegion)) {
    regionSelect.value = savedRegion;
  }
  regionSelect.addEventListener('change', () => {
    localStorage.setItem('rt-broadcast-region', regionSelect.value);
    renderBroadcast(currentEvent?.seriesId);
  });

  function renderBroadcast(seriesId?: string) {
    if (!seriesId || !broadcastDb.series?.[seriesId]) {
      broadcastSection.classList.add('hidden');
      return;
    }
    const region = regionSelect.value;
    const channels: BroadcastChannel[] = broadcastDb.series[seriesId][region] ?? [];
    if (channels.length === 0) {
      broadcastSection.classList.add('hidden');
      return;
    }
    broadcastSection.classList.remove('hidden');
    broadcastList.innerHTML = channels.map((ch) => {
      const icon = ch.type === 'streaming'
        ? '<svg class="w-3.5 h-3.5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 0 1 0 .656l-5.603 3.113a.375.375 0 0 1-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112Z" /></svg>'
        : '<svg class="w-3.5 h-3.5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 20.25h12m-7.5-3v3m3-3v3m-10.125-3h17.25c.621 0 1.125-.504 1.125-1.125V4.875c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125Z" /></svg>';
      return `<div class="flex items-center gap-2.5 px-3 py-2 rounded-lg hover:bg-zinc-900">
        ${icon}
        <span class="text-sm text-zinc-300 font-medium">${ch.channel}</span>
        <span class="text-[10px] uppercase tracking-wide font-semibold ${ch.type === 'streaming' ? 'text-blue-400' : 'text-zinc-500'}">${ch.type}</span>
        ${ch.note ? `<span class="text-[10px] text-zinc-600 ml-auto">${ch.note}</span>` : ''}
      </div>`;
    }).join('');
  }

  // ── Series metadata (imported from series-client.ts) ──

  function isRaceType(type: string) { return type === 'Race' || type === 'Feature Race'; }

  const modal = document.getElementById('event-modal')!;

  function openModal(event: RaceEvent) {
    const meta = getClientSeriesMeta(event.seriesId);
    const base = (document.getElementById('event-modal')!.dataset.base ?? '');
    const isFav = readFavorites().includes(event.id);
    const isPast = isPastEvent(event.dateEnd);

    // Color bar
    (document.getElementById('modal-color-bar') as HTMLElement).style.background = meta.color;

    // Badge
    const badge = document.getElementById('modal-badge') as HTMLElement;
    badge.textContent = meta.shortLabel;
    badge.style.backgroundColor = meta.color;

    // Round
    (document.getElementById('modal-round') as HTMLElement).textContent = `Round ${event.round}`;

    // Title
    (document.getElementById('modal-title') as HTMLElement).textContent = event.eventName;

    // Circuit
    const circuitEl = document.getElementById('modal-circuit') as HTMLElement;
    const flag = countryFlag(event.circuit.countryCode);
    circuitEl.innerHTML = `
      ${flag ? `<span class="text-lg">${flag}</span>` : ''}
      <span class="font-medium text-zinc-300">${event.circuit.name}</span>
      ${event.circuit.city ? `<span class="text-zinc-600">·</span><span>${event.circuit.city}</span>` : ''}
      ${event.circuit.country ? `<span class="text-zinc-600">·</span><span>${event.circuit.country}</span>` : ''}
    `;

    // Sessions
    const sessionsEl = document.getElementById('modal-sessions') as HTMLElement;
    const validSessions = event.sessions.filter((session) => !isPlaceholderTime(session.startTimeUTC));
    sessionsEl.innerHTML = validSessions.map((s) => {
      const isRace = isRaceType(s.type);
      const isPastSession = new Date(s.startTimeUTC) < new Date();
      const isLive = isSessionLive(s);
      const isNext = !isPastSession && !isLive && validSessions.filter((x) => new Date(x.startTimeUTC) < new Date()).length === validSessions.indexOf(s);
      const label = SESSION_LABELS[s.type] ?? s.type;
      const dotColor = isLive ? '#10b981' : isRace ? meta.color : isPastSession ? '#27272a' : '#52525b';
      const sleep = !isPastSession && !isLive ? sleepVerdict(s.startTimeUTC) : null;

      return `
        <div class="flex items-center gap-3 px-3 py-2.5 rounded-lg ${isLive ? 'bg-emerald-950/30 ring-1 ring-emerald-800/50' : isPastSession ? 'opacity-40' : isNext ? 'bg-zinc-800/80 ring-1 ring-zinc-700' : 'hover:bg-zinc-900'}">
          <span class="w-2 h-2 rounded-full shrink-0 ${isLive ? 'live-pulse' : ''}" style="background-color:${dotColor}"></span>
          <span class="flex-1 text-sm font-semibold ${isLive ? 'text-emerald-300' : isRace ? 'text-zinc-100' : isPastSession ? 'text-zinc-600' : 'text-zinc-300'}">${label}</span>
          <time class="text-sm tabular-nums font-mono ${isPastSession ? 'text-zinc-700' : isRace ? 'text-zinc-200' : 'text-zinc-400'}" title="${s.startTimeUTC}">
            ${formatLocalDatetime(s.startTimeUTC)}
          </time>
          ${isLive ? '<span class="live-pulse inline-flex items-center gap-1 text-[10px] text-emerald-400 font-bold uppercase tracking-wide ml-1"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block"></span>Live</span>' : ''}
          ${sleep ? `<span class="text-[10px] ${sleep.cssClass} font-semibold ml-1" title="${sleep.label}">${sleep.emoji}</span>` : ''}
          ${isPastSession && !isLive ? '<span class="text-[10px] text-zinc-700 font-semibold uppercase tracking-wide ml-2">Done</span>' : ''}
        </div>
      `;
    }).join('');

    // Series link
    const link = document.getElementById('modal-series-link') as HTMLAnchorElement;
    link.href = `${base}/series/${event.seriesId}`;
    link.textContent = `View full ${meta.label} schedule →`;

    // Status badge
    const statusBadge = document.getElementById('modal-status-badge') as HTMLElement;
    if (isPast) {
      statusBadge.textContent = 'Completed';
      statusBadge.className = 'text-xs px-2 py-1 rounded-full font-semibold bg-zinc-800 text-zinc-500';
    } else {
      statusBadge.textContent = 'Upcoming';
      statusBadge.className = 'text-xs px-2 py-1 rounded-full font-semibold';
      statusBadge.style.backgroundColor = meta.color + '20';
      statusBadge.style.color = meta.color;
    }

    // Favorite button (class modal-fav-btn — intentionally different from .fav-btn on cards)
    const favBtn = document.getElementById('modal-fav-btn') as HTMLButtonElement;
    favBtn.dataset.fav = isFav ? 'true' : 'false';
    favBtn.onclick = () => {
      const nowFav = toggleFavorite(event.id);
      favBtn.dataset.fav = nowFav ? 'true' : 'false';
    };

    // Reset to list view when opening modal
    showListView();

    // Render broadcast info
    renderBroadcast(event.seriesId);

    // Update alert UI
    updateAlertUI();

    // Render timeline (lazy — only when switched to)
    currentEvent = event;

    // Deeplink: reflect this event in URL
    const dlUrl = new URL(window.location.href);
    dlUrl.searchParams.set('event', event.id);
    history.replaceState(null, '', dlUrl.toString());

    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('open');
    document.body.style.overflow = '';
    // Remove event from URL
    const dlUrl = new URL(window.location.href);
    dlUrl.searchParams.delete('event');
    history.replaceState(null, '', dlUrl.toString());
  }

  // ── View toggle ──
  let currentEvent: RaceEvent | null = null;
  const sessionsEl = document.getElementById('modal-sessions')!;
  const timelineEl = document.getElementById('weekend-timeline')!;
  const listBtn = document.getElementById('view-list-btn')!;
  const tlBtn = document.getElementById('view-timeline-btn')!;

  function showListView() {
    sessionsEl.classList.remove('hidden');
    timelineEl.classList.add('hidden');
    listBtn.classList.add('bg-zinc-700', 'text-zinc-200');
    listBtn.classList.remove('text-zinc-500');
    listBtn.setAttribute('aria-pressed', 'true');
    tlBtn.classList.remove('bg-zinc-700', 'text-zinc-200');
    tlBtn.classList.add('text-zinc-500');
    tlBtn.setAttribute('aria-pressed', 'false');
  }

  function showTimelineView() {
    sessionsEl.classList.add('hidden');
    timelineEl.classList.remove('hidden');
    tlBtn.classList.add('bg-zinc-700', 'text-zinc-200');
    tlBtn.classList.remove('text-zinc-500');
    tlBtn.setAttribute('aria-pressed', 'true');
    listBtn.classList.remove('bg-zinc-700', 'text-zinc-200');
    listBtn.classList.add('text-zinc-500');
    listBtn.setAttribute('aria-pressed', 'false');
    if (currentEvent && (window as any).__renderTimeline) {
      (window as any).__renderTimeline(currentEvent);
    }
  }

  listBtn.addEventListener('click', showListView);
  tlBtn.addEventListener('click', showTimelineView);

  document.getElementById('modal-close')!.addEventListener('click', closeModal);
  document.getElementById('modal-backdrop')!.addEventListener('click', closeModal);
  window.addEventListener('rt-open-event', (e: Event) => openModal((e as CustomEvent).detail));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  document.addEventListener('astro:before-swap', () => { document.body.style.overflow = ''; });

  // ── Share button ──
  const shareBtn = document.getElementById('modal-share-btn')!;
  const shareToast = document.getElementById('modal-share-toast')!;
  let shareToastTimer: ReturnType<typeof setTimeout> | null = null;

  // ── ICS export button ──
  document.getElementById('modal-ics-btn')!.addEventListener('click', () => {
    if (currentEvent) exportEventIcs(currentEvent);
  });

  // ── Session alerts ──
  const alertSection = document.getElementById('modal-alert')!;
  const alertOffsetSelect = document.getElementById('alert-offset') as HTMLSelectElement;
  const alertSetBtn = document.getElementById('alert-set-btn')!;
  const alertStatus = document.getElementById('alert-status')!;
  const RT_ALERTS_KEY = 'rt-alerts';

  interface StoredAlert { eventId: string; eventName: string; sessionType: string; fireAt: string; offset: number; }

  function getAlerts(): StoredAlert[] {
    try { return JSON.parse(localStorage.getItem(RT_ALERTS_KEY) ?? '[]'); } catch { return []; }
  }
  function saveAlerts(alerts: StoredAlert[]) {
    localStorage.setItem(RT_ALERTS_KEY, JSON.stringify(alerts));
  }

  function updateAlertUI() {
    if (!currentEvent) { alertSection.classList.add('hidden'); return; }
    const eventId = currentEvent.id;
    // Find race session
    const race = currentEvent.sessions?.find((s) => s.type === 'Race' || s.type === 'Feature Race');
    if (!race || new Date(race.startTimeUTC) < new Date()) {
      alertSection.classList.add('hidden');
      return;
    }
    alertSection.classList.remove('hidden');
    // Check if alert already set
    const alerts = getAlerts();
    const existing = alerts.find((a: StoredAlert) => a.eventId === eventId);
    if (existing) {
      alertStatus.textContent = `Reminder set: ${existing.offset} min before race`;
      alertStatus.classList.remove('hidden');
      alertSetBtn.textContent = 'Remove';
    } else {
      alertStatus.classList.add('hidden');
      alertSetBtn.textContent = 'Set';
    }
  }

  alertSetBtn.addEventListener('click', async () => {
    if (!currentEvent) return;
    const eventId = currentEvent.id;
    const alerts = getAlerts();
    const existing = alerts.findIndex((a: StoredAlert) => a.eventId === eventId);
    if (existing >= 0) {
      alerts.splice(existing, 1);
      saveAlerts(alerts);
      updateAlertUI();
      return;
    }
    // Request notification permission
    if ('Notification' in window && Notification.permission === 'default') {
      await Notification.requestPermission();
    }
    if ('Notification' in window && Notification.permission !== 'granted') {
      alertStatus.textContent = 'Notifications blocked — enable in browser settings';
      alertStatus.classList.remove('hidden');
      return;
    }
    const race = currentEvent.sessions?.find((s) => s.type === 'Race' || s.type === 'Feature Race');
    if (!race) return;
    const offset = parseInt(alertOffsetSelect.value);
    const fireAt = new Date(new Date(race.startTimeUTC).getTime() - offset * 60000).toISOString();
    alerts.push({ eventId, eventName: currentEvent.eventName, sessionType: race.type, fireAt, offset });
    saveAlerts(alerts);
    updateAlertUI();
  });

  // Check and fire pending alerts every 30s
  function checkAlerts() {
    if (!('Notification' in window) || Notification.permission !== 'granted') return;
    const alerts = getAlerts();
    const now = Date.now();
    const remaining: StoredAlert[] = [];
    for (const alert of alerts) {
      if (new Date(alert.fireAt).getTime() <= now) {
        new Notification(`🏁 ${alert.eventName}`, {
          body: `${alert.sessionType} starts in ${alert.offset} minutes!`,
          icon: (document.getElementById('event-modal')?.dataset.base ?? '') + '/icon-192.png',
        });
      } else {
        remaining.push(alert);
      }
    }
    if (remaining.length !== alerts.length) saveAlerts(remaining);
  }
  setInterval(checkAlerts, 30000);
  checkAlerts();

  shareBtn.addEventListener('click', async () => {
    if (!currentEvent) return;
    const shareUrl = new URL(window.location.href);
    shareUrl.searchParams.set('event', currentEvent.id);
    const url = shareUrl.toString();
    if (typeof navigator.share === 'function') {
      try {
        await navigator.share({ title: currentEvent.eventName, url });
        return;
      } catch (err) {
        if ((err as Error).name === 'AbortError') return;
      }
    }
    try { await navigator.clipboard.writeText(url); } catch {}
    shareToast.classList.remove('hidden');
    if (shareToastTimer) clearTimeout(shareToastTimer);
    shareToastTimer = setTimeout(() => shareToast.classList.add('hidden'), 2000);
  });

  // ── Deeplink: open event from ?event= param on page load ──
  (function resolveDeeplink() {
    const eventId = new URLSearchParams(window.location.search).get('event');
    if (!eventId) return;
    // 1. Try EventCard DOM elements (index/calendar pages)
    const el = document.querySelector(`[data-event-id="${CSS.escape(eventId)}"]`);
    if (el) {
      try {
        const ev = JSON.parse((el as HTMLElement).getAttribute('data-event') ?? '');
        if (ev?.id) { openModal(ev); return; }
      } catch {}
    }
    // 2. Try page-registered event list (__rtAllEvents or __passportFullEvents)
    const all: RaceEvent[] | undefined = (window as any).__rtAllEvents ?? (window as any).__passportFullEvents;
    if (all) {
      const ev = all.find((e) => e.id === eventId);
      if (ev) openModal(ev);
    }
  })();
</script>
