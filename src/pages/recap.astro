---
import Layout from '../layouts/Layout.astro';
import SeriesBadge from '../components/SeriesBadge.astro';
import { getSeriesMeta } from '../lib/series';
import { formatDateRange, countryFlag, isPastEvent } from '../lib/time';
import type { RaceEvent } from '../lib/types';
import calendarData from '../../data/gold/calendar.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allEvents = (calendarData as any).events as RaceEvent[];
const now = new Date();

// Events that ended in the past 7 days
const weekAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
const recentEvents = allEvents
  .filter(e => {
    const end = new Date(e.dateEnd + 'T23:59:59Z');
    return end >= weekAgo && end < now;
  })
  .sort((a, b) => b.dateEnd.localeCompare(a.dateEnd));

// Unique series that raced
const seriesSet = new Set(recentEvents.map(e => e.seriesId));
---

<Layout title="RaceTrack — Recap" currentPath={`${base}/recap`}>
  <main class="max-w-3xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-black tracking-tight mb-1">What Did I Miss?</h1>
      <p class="text-zinc-400 text-sm">Events from the past 7 days</p>
    </div>

    {recentEvents.length > 0 ? (
      <>
        {/* Summary header */}
        <div class="mb-6 flex items-center gap-3 flex-wrap">
          <span class="text-lg">🏁</span>
          <span class="text-sm font-semibold text-zinc-300">
            {recentEvents.length} event{recentEvents.length !== 1 ? 's' : ''} across {seriesSet.size} series
          </span>
          <button
            id="spoiler-toggle"
            class="ml-auto text-xs text-zinc-500 hover:text-zinc-300 transition-colors border border-zinc-800 hover:border-zinc-600 rounded-lg px-3 py-1.5 flex items-center gap-1.5"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
            </svg>
            Spoiler-free mode
          </button>
        </div>

        {/* Recent events list */}
        <div class="space-y-3" id="recap-list">
          {recentEvents.map(event => {
            const meta = getSeriesMeta(event.seriesId);
            const flag = countryFlag(event.circuit.countryCode);
            return (
              <article
                class="group relative rounded-xl border border-zinc-800 bg-zinc-900/70 hover:border-zinc-700 hover:bg-zinc-900 transition-all cursor-pointer"
                data-event={JSON.stringify(event).replace(/'/g, '&#39;')}
                data-event-id={event.id}
              >
                <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full" style={`background-color: ${meta.color};`} />
                <div class="px-5 py-4">
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <div class="flex items-center gap-2 flex-wrap">
                      <SeriesBadge seriesId={event.seriesId} />
                      <span class="text-[11px] text-zinc-500 font-mono">Rd {event.round}</span>
                      <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-zinc-800 text-zinc-600 font-semibold uppercase tracking-widest">
                        Done
                      </span>
                    </div>
                    <span class="text-sm font-medium text-zinc-400 tabular-nums shrink-0">
                      {formatDateRange(event.dateStart, event.dateEnd)}
                    </span>
                  </div>
                  <h3 class="font-bold text-base leading-tight mb-2 text-zinc-100 recap-spoiler-text">
                    {event.eventName}
                  </h3>
                  <div class="flex items-center gap-1.5 text-sm text-zinc-500 recap-spoiler-text">
                    {flag && <span class="text-base leading-none">{flag}</span>}
                    <span class="text-zinc-400">{event.circuit.name}</span>
                    {event.circuit.city && <span class="text-zinc-700">·</span>}
                    {event.circuit.city && <span>{event.circuit.city}</span>}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </>
    ) : (
      <div class="text-center py-20 text-zinc-600">
        <div class="text-5xl mb-4">📺</div>
        <p class="font-semibold mb-1 text-zinc-500">Nothing recent</p>
        <p class="text-sm">No events completed in the past 7 days.</p>
      </div>
    )}
  </main>
</Layout>

<script>
  // Spoiler-free toggle
  const toggle = document.getElementById('spoiler-toggle');
  let spoilerFree = false;

  function applySpoiler() {
    document.querySelectorAll('.recap-spoiler-text').forEach(el => {
      (el as HTMLElement).style.filter = spoilerFree ? 'blur(8px)' : '';
      (el as HTMLElement).style.userSelect = spoilerFree ? 'none' : '';
    });
    if (toggle) {
      toggle.classList.toggle('text-amber-400', spoilerFree);
      toggle.classList.toggle('border-amber-800', spoilerFree);
    }
  }

  toggle?.addEventListener('click', () => {
    spoilerFree = !spoilerFree;
    applySpoiler();
  });

  // Card click → open modal
  document.querySelectorAll<HTMLElement>('#recap-list [data-event-id]').forEach(card => {
    card.addEventListener('click', () => {
      try {
        const event = JSON.parse(card.dataset.event!);
        window.dispatchEvent(new CustomEvent('rt-open-event', { detail: event }));
      } catch {}
    });
  });
</script>
