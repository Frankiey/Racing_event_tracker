---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import type { RaceEvent } from '../lib/types';

import calendarData from '../../data/gold/calendar.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allEvents = (calendarData as any).events as RaceEvent[];
---

<Layout title="RaceTrack — My Watchlist" currentPath={`${base}/watchlist`}>
  <main class="max-w-5xl mx-auto px-4 py-8">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <h1 class="text-2xl font-black tracking-tight mb-1">My Watchlist</h1>
        <p class="text-zinc-400 text-sm">Events you've saved. Click the ♥ on any event to add it.</p>
      </div>
      <button
        id="export-ics"
        class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors border border-zinc-800 hover:border-zinc-600 rounded-lg px-3 py-1.5 flex items-center gap-1.5"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
        Export .ics
      </button>
      <button
        id="clear-favs"
        class="text-xs text-zinc-600 hover:text-rose-400 transition-colors border border-zinc-800 hover:border-rose-800 rounded-lg px-3 py-1.5"
      >
        Clear all
      </button>
    </div>

    <!-- Empty state -->
    <div id="watchlist-empty" class="text-center py-20 text-zinc-600">
      <div class="text-5xl mb-4">♥</div>
      <p class="font-semibold mb-1 text-zinc-500">Nothing saved yet</p>
      <p class="text-sm">Hit the heart on any event card to watch it here.</p>
    </div>

    <!-- Events — rendered by JS from localStorage -->
    <div id="watchlist-grid" class="grid gap-3 hidden" />

    <!-- All events data for client-side rendering -->
    <script id="all-events-data" type="application/json" set:html={JSON.stringify(allEvents)} />
  </main>
</Layout>

<script>
  import { SESSION_ABBR } from '../lib/sessions';
  import { SERIES_META } from '../lib/series-client';
  import { countryFlag, escapeHtml, formatLocalTime, formatDateRange, isPastEvent, isPlaceholderTime, readFavorites, toggleFavorite, safeJsonParse } from '../lib/client-utils';
  import { exportEventsIcs } from '../lib/ics';
  import type { RaceEvent } from '../lib/types';

  const allEvents: RaceEvent[] = safeJsonParse(
    document.getElementById('all-events-data')!.textContent!, []
  );

  function render() {
    const favs = readFavorites();
    const grid = document.getElementById('watchlist-grid')!;
    const empty = document.getElementById('watchlist-empty')!;

    const favEvents = allEvents
      .filter(e => favs.includes(e.id))
      .sort((a, b) => a.dateStart.localeCompare(b.dateStart));

    if (favEvents.length === 0) {
      grid.classList.add('hidden');
      empty.classList.remove('hidden');
      return;
    }

    empty.classList.add('hidden');
    grid.classList.remove('hidden');

    grid.innerHTML = favEvents.map(ev => {
      const meta = SERIES_META[ev.seriesId] ?? { label: ev.seriesId, shortLabel: ev.seriesId, color: '#71717a' };
      const past = isPastEvent(ev.dateEnd);
      const f = countryFlag(ev.circuit?.countryCode ?? '');
      const validSessions = (ev.sessions ?? []).filter((s: any) => !isPlaceholderTime(s.startTimeUTC));

      const sessionsHtml = validSessions.map((s: any) => {
        const isRace = s.type === 'Race' || s.type === 'Feature Race';
        const t = formatLocalTime(s.startTimeUTC);
        return `<div class="flex items-center gap-1.5 text-xs">
          <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background-color:${isRace ? meta.color : '#3f3f46'}"></span>
          <span class="font-semibold ${isRace ? 'text-zinc-100' : 'text-zinc-500'}">${SESSION_ABBR[s.type] ?? s.type}</span>
          <span class="tabular-nums text-zinc-600">${t}</span>
        </div>`;
      }).join('');

      return `
        <article
          class="group relative rounded-xl border transition-all duration-200 cursor-pointer ${past ? 'border-zinc-800/40 bg-zinc-900/20 opacity-40' : 'border-zinc-800 bg-zinc-900/70 hover:border-zinc-700 hover:bg-zinc-900'}"
          data-event='${escapeHtml(JSON.stringify(ev))}'
          data-event-id="${escapeHtml(ev.id)}"
          role="button" tabindex="0"
        >
          <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full" style="background-color:${meta.color}"></div>
          <div class="px-5 py-4">
            <div class="flex items-start justify-between gap-3 mb-2">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="inline-block rounded font-bold uppercase tracking-wide text-white text-xs px-2 py-0.5" style="background-color:${meta.color}">${meta.shortLabel}</span>
                <span class="text-[11px] text-zinc-500 font-mono">Rd ${ev.round}</span>
                ${past ? '<span class="text-[10px] px-1.5 py-0.5 rounded-full bg-zinc-800 text-zinc-600 font-semibold uppercase tracking-widest">Done</span>' : ''}
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <span class="text-sm font-medium text-zinc-400 tabular-nums">${formatDateRange(ev.dateStart, ev.dateEnd)}</span>
                <button class="fav-btn p-1 rounded-full hover:bg-zinc-800 transition-colors" data-fav="true" data-fav-id="${escapeHtml(ev.id)}" aria-label="Remove from favorites">
                  <svg class="w-4 h-4 fill-rose-500 stroke-rose-500" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                  </svg>
                </button>
              </div>
            </div>
            <h3 class="font-bold text-base leading-tight mb-2 ${past ? 'text-zinc-500' : 'text-zinc-100'}">${escapeHtml(ev.eventName)}</h3>
            <div class="flex items-center gap-1.5 text-sm text-zinc-500 mb-3">
              ${f ? `<span class="text-base">${f}</span>` : ''}
              <span class="text-zinc-400">${escapeHtml(ev.circuit?.name ?? '')}</span>
              ${ev.circuit?.city ? `<span class="text-zinc-700">·</span><span>${escapeHtml(ev.circuit.city)}</span>` : ''}
            </div>
            ${validSessions.length > 0 ? `<div class="flex flex-wrap gap-x-4 gap-y-1.5 pt-2 border-t border-zinc-800/60">${sessionsHtml}</div>` : ''}
          </div>
        </article>
      `;
    }).join('');

    // Wire up events on rendered cards
    grid.querySelectorAll<HTMLElement>('[data-event-id]').forEach(card => {
      card.addEventListener('click', () => {
        try {
          window.dispatchEvent(new CustomEvent('rt-open-event', { detail: JSON.parse(card.dataset.event!) }));
        } catch { /* invalid JSON in data attr — ignore */ }
      });
    });
    grid.querySelectorAll<HTMLButtonElement>('.fav-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleFavorite(btn.dataset.favId!);
      });
    });
  }

  render();
  window.addEventListener('rt-favs-changed', render);

  document.getElementById('clear-favs')!.addEventListener('click', () => {
    if (confirm('Clear your entire watchlist?')) {
      localStorage.removeItem('rt-favs');
      window.dispatchEvent(new CustomEvent('rt-favs-changed'));
    }
  });

  document.getElementById('export-ics')!.addEventListener('click', () => {
    const favs = readFavorites();
    const favEvents = allEvents.filter(e => favs.includes(e.id));
    if (favEvents.length === 0) return;
    exportEventsIcs('RaceTrack Watchlist', favEvents);
  });
</script>
