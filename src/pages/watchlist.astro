---
import Layout from '../layouts/Layout.astro';
import type { EventFeed } from '../lib/types';

import calendarData from '../../data/gold/calendar.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allEvents = (calendarData as EventFeed).events;
---

<Layout title="RaceTrack — My Watchlist" currentPath={`${base}/watchlist`}>
  <main class="max-w-5xl mx-auto px-4 py-8">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <h1 class="text-2xl font-black tracking-tight mb-1">My Watchlist</h1>
        <p class="text-zinc-400 text-sm">Events you've saved. Click the ♥ on any event to add it.</p>
      </div>
      <button
        id="export-ics"
        class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors border border-zinc-800 hover:border-zinc-600 rounded-lg px-3 py-1.5 flex items-center gap-1.5"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
        Export .ics
      </button>
      <button
        id="clear-favs"
        class="text-xs text-zinc-600 hover:text-rose-400 transition-colors border border-zinc-800 hover:border-rose-800 rounded-lg px-3 py-1.5"
      >
        Clear all
      </button>
    </div>

    <!-- Empty state -->
    <div id="watchlist-empty" class="text-center py-20 text-zinc-600">
      <div class="text-5xl mb-4">♥</div>
      <p class="font-semibold mb-1 text-zinc-500">Nothing saved yet</p>
      <p class="text-sm">Hit the heart on any event card to watch it here.</p>
    </div>

    <!-- Events — rendered by JS from localStorage -->
    <div id="watchlist-grid" class="grid gap-3 hidden" />

    <!-- All events data for client-side rendering -->
    <script id="all-events-data" type="application/json" set:html={JSON.stringify(allEvents)} is:inline />
  </main>
</Layout>

<script>
  import { bindEventOpeners, registerEvents } from '../lib/event-client';
  import { readFavorites, toggleFavorite, safeJsonParse } from '../lib/client-utils';
  import { renderClientEventCard } from '../lib/event-card-renderer';
  import { exportEventsIcs } from '../lib/ics';
  import type { RaceEvent } from '../lib/types';

  const allEvents: RaceEvent[] = safeJsonParse(
    document.getElementById('all-events-data')!.textContent!, []
  );

  registerEvents(allEvents);

  function render() {
    const favs = readFavorites();
    const grid = document.getElementById('watchlist-grid')!;
    const empty = document.getElementById('watchlist-empty')!;

    const favEvents = allEvents
      .filter(e => favs.includes(e.id))
      .sort((a, b) => a.dateStart.localeCompare(b.dateStart));

    if (favEvents.length === 0) {
      grid.classList.add('hidden');
      empty.classList.remove('hidden');
      return;
    }

    empty.classList.add('hidden');
    grid.classList.remove('hidden');

    grid.innerHTML = favEvents.map(ev => renderClientEventCard(ev, {
      variant: 'watchlist',
      favoriteState: true,
    })).join('');

    bindEventOpeners(grid);
    grid.querySelectorAll<HTMLButtonElement>('.fav-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        toggleFavorite(btn.dataset.favId!);
      });
    });
  }

  render();
  window.addEventListener('rt-favs-changed', render);

  document.getElementById('clear-favs')!.addEventListener('click', () => {
    if (confirm('Clear your entire watchlist?')) {
      localStorage.removeItem('rt-favs');
      window.dispatchEvent(new CustomEvent('rt-favs-changed'));
    }
  });

  document.getElementById('export-ics')!.addEventListener('click', () => {
    const favs = readFavorites();
    const favEvents = allEvents.filter(e => favs.includes(e.id));
    if (favEvents.length === 0) return;
    exportEventsIcs('RaceTrack Watchlist', favEvents);
  });
</script>
