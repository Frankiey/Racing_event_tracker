---
import Layout from '../layouts/Layout.astro';
import { SERIES_LIST } from '../lib/series';
import type { EventFeed } from '../lib/types';
import calendarData from '../../data/gold/calendar.json';

import { isPastEvent } from '../lib/time';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const allEvents = (calendarData as EventFeed).events;

// Build per-series event data with coordinates for the globe
// Only include events that have valid lat/lng
const seriesEvents: Record<string, any[]> = {};
for (const event of allEvents) {
  const c = event.circuit;
  if (c.lat == null || c.lng == null) continue;
  if (!seriesEvents[event.seriesId]) seriesEvents[event.seriesId] = [];
  const isPast = isPastEvent(event.dateEnd, event.sessions);
  seriesEvents[event.seriesId].push({
    id: event.id,
    name: event.eventName,
    round: event.round,
    lat: c.lat,
    lng: c.lng,
    circuit: c.name,
    city: c.city || '',
    country: c.country || '',
    countryCode: c.countryCode || '',
    dateStart: event.dateStart,
    dateEnd: event.dateEnd,
    isPast,
    seriesId: event.seriesId,
  });
}

// Series with at least one event that has coords
const availableSeries = SERIES_LIST.filter(s => seriesEvents[s.id]?.length > 0);

// Series with enough events to fly a route (≥2)
const flightableSeries = SERIES_LIST.filter(s => (seriesEvents[s.id]?.length ?? 0) >= 2);

// Flatten all events into a JSON blob for the client
const allGlobeEvents = Object.values(seriesEvents).flat();

// Series meta for client
const seriesMeta: Record<string, { label: string; shortLabel: string; color: string }> = {};
for (const s of SERIES_LIST) {
  seriesMeta[s.id] = { label: s.label, shortLabel: s.shortLabel, color: s.color };
}
---

<Layout title="RaceTrack — Season Passport" currentPath={`${base}/passport`}>
  <main class="max-w-6xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="mb-6">
      <a href={`${base}/`} class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors mb-4 inline-block">
        ← Back to dashboard
      </a>
      <h1 class="text-3xl font-black tracking-tight mb-1">Season Passport</h1>
      <p class="text-zinc-400 text-sm">The 2026 motorsport journey around the world</p>
    </div>

    <!-- Series filter pills -->
    <div class="mb-6">
      <div class="flex flex-wrap gap-2" id="passport-filters">
        <button
          data-filter="all"
          class="passport-filter-btn active px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wide border border-zinc-700 bg-zinc-800 text-zinc-200 transition-all"
        >
          All Series
        </button>
        {availableSeries.map(s => (
          <button
            data-filter={s.id}
            class="passport-filter-btn px-3 py-1.5 rounded-lg text-xs font-bold uppercase tracking-wide border border-zinc-800 text-zinc-500 hover:text-zinc-300 hover:border-zinc-700 transition-all flex items-center gap-1.5"
          >
            <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${s.color}`} />
            {s.shortLabel}
          </button>
        ))}
      </div>
    </div>

    <!-- Globe + info panel -->
    <div class="grid lg:grid-cols-[1fr_320px] gap-6">
      <!-- Globe -->
      <div class="relative rounded-2xl border border-zinc-800/60 overflow-hidden" style="min-height: 560px; background: radial-gradient(ellipse at center, #0d1117 0%, #050810 100%);">
        <canvas id="globe-canvas" class="w-full h-full block cursor-grab active:cursor-grabbing" style="min-height: 560px;" />
        <div id="globe-tooltip" class="hidden absolute bg-zinc-900/95 border border-zinc-700/60 rounded-xl shadow-2xl shadow-black/60 px-4 py-3 pointer-events-none z-10 max-w-[240px]" />
        <!-- Controls -->
        <div class="absolute bottom-4 left-4 flex gap-2">
          <button id="globe-zoom-in" class="p-2 rounded-lg bg-zinc-800/80 border border-zinc-700/40 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-700/80 transition-colors" aria-label="Zoom in">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 6v12M6 12h12"/></svg>
          </button>
          <button id="globe-zoom-out" class="p-2 rounded-lg bg-zinc-800/80 border border-zinc-700/40 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-700/80 transition-colors" aria-label="Zoom out">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M6 12h12"/></svg>
          </button>
          <button id="globe-reset" class="p-2 rounded-lg bg-zinc-800/80 border border-zinc-700/40 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-700/80 transition-colors text-[10px] font-bold" aria-label="Reset view">
            ↻
          </button>
          <button id="globe-pause" class="p-2 rounded-lg bg-zinc-800/80 border border-zinc-700/40 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-700/80 transition-colors" aria-label="Pause/play flight" title="Pause/play flight animation">
            <svg id="pause-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25v13.5m-7.5-13.5v13.5"/></svg>
            <svg id="play-icon" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z"/></svg>
          </button>
          <button id="globe-follow" class="p-2 rounded-lg bg-zinc-800/80 border border-zinc-700/40 text-emerald-400 hover:text-emerald-300 hover:bg-zinc-700/80 transition-colors" aria-label="Toggle follow plane" title="Follow plane">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0 1 15 0Z"/></svg>
          </button>
        </div>
        <!-- Stats overlay -->
        <div class="absolute top-4 right-4 text-right">
          <div id="globe-stats" class="text-[10px] uppercase tracking-widest text-zinc-500 font-bold space-y-1" />
        </div>
      </div>

      <!-- Event info panel -->
      <div id="event-panel" class="rounded-2xl border border-zinc-800/60 bg-zinc-900/40 p-5 flex flex-col">
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-4">Selected Event</h3>
        <div id="event-panel-content" class="flex-1 flex items-center justify-center">
          <p class="text-sm text-zinc-600 text-center">Click a dot on the globe to see event details</p>
        </div>
      </div>
    </div>

    <!-- Flight route selector -->
    <div class="mt-5">
      <div class="flex items-center gap-3 flex-wrap">
        <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 whitespace-nowrap">✈ Flying route</span>
        <div class="flex flex-wrap gap-1.5" id="flight-series-btns">
          {flightableSeries.map((s, i) => (
            <button
              data-flight-series={s.id}
              class:list={[
                'flight-series-btn px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wide border transition-all flex items-center gap-1',
                i === 0
                  ? 'border-zinc-600 bg-zinc-800 text-zinc-200'
                  : 'border-zinc-800 text-zinc-600 hover:text-zinc-300 hover:border-zinc-700'
              ]}
            >
              <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background-color: ${s.color}`} />
              {s.shortLabel}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Route list (compact legend below globe) -->
    <div class="mt-4">
      <div class="flex items-center gap-3 mb-3">
        <h3 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">Legend</h3>
        <span class="h-px flex-1 bg-zinc-800/60" />
      </div>
      <div class="flex items-center gap-6 text-xs text-zinc-500">
        <span class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-full bg-zinc-400" /> Completed
        </span>
        <span class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-full border-2 border-zinc-400 bg-transparent" style="box-shadow: 0 0 6px rgba(255,255,255,0.3);" /> Next race
        </span>
        <span class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-full border-2 border-zinc-600 bg-transparent" /> Upcoming
        </span>
      </div>
    </div>
  </main>
</Layout>

<script type="application/json" id="globe-data" set:html={JSON.stringify({
  events: allGlobeEvents,
  seriesMeta,
  flightableSeriesIds: flightableSeries.map(s => s.id),
  fullEvents: allEvents,
})} is:inline />

<script>
  // ═══ Season Passport — D3 Orthographic Globe ═══
  import { drag } from 'd3-drag';
  import { select } from 'd3-selection';
  import { feature } from 'topojson-client';
  import { renderEmptyPassportPanel, renderPassportEventPanel } from '../lib/passport/panel';
  import { createPassportRenderer } from '../lib/passport/renderer';
  import {
    applyPassportFilterButtonState,
    applyPassportFlightSeriesButtonState,
    findNearestProjectedEvent,
    renderPassportStats,
    renderPassportTooltip,
    setPassportFlightSeries,
    updatePassportFlightState,
  } from '../lib/passport/state';
  import type {
    PassportEvent,
    PassportFullEvent,
    PassportRenderState,
    PassportSeriesMetaMap,
  } from '../lib/passport/types';
  // @ts-ignore — world-atlas ships JSON
  import worldData from 'world-atlas/land-110m.json';

  const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;
  const tooltip = document.getElementById('globe-tooltip')!;
  const panel = document.getElementById('event-panel-content')!;
  const statsEl = document.getElementById('globe-stats')!;

  // ── World geometry from topojson ──
  const land = feature(worldData as any, (worldData as any).objects.land);

  // ── Parse embedded data ──
  const __data = JSON.parse(document.getElementById('globe-data')!.textContent!);

  // ── State ──
  const events: PassportEvent[] = __data.events;
  const meta: PassportSeriesMetaMap = __data.seriesMeta;
  const FLIGHT_SPEED = 0.004; // progress per frame
  const flightableIds: string[] = __data.flightableSeriesIds ?? ['f1'];
  const fullEvents: PassportFullEvent[] = __data.fullEvents ?? [];
  const renderState: PassportRenderState = {
    activeFilter: 'all',
    hoveredEvent: null,
    selectedEvent: null,
    autoRotate: true,
    lastInteraction: 0,
    currentRotation: [0, -20, 0],
    velocityX: 0,
    scaleFactor: 1,
    flightProgress: 0,
    flightActive: false,
    flightPaused: false,
    followPlane: true,
    flightSeries: flightableIds[0] ?? 'f1',
    lastFlightSegIndex: -1,
    isDragging: false,
    projectedDots: [],
  };

  function updateStats() {
    statsEl.innerHTML = renderPassportStats(events, renderState.activeFilter);
  }

  function updateFlightState() {
    updatePassportFlightState(renderState, events);
  }

  function setFlightSeries(sid: string) {
    setPassportFlightSeries(renderState, sid, events);
    updateFlightSeriesUI();
  }

  function updateFlightSeriesUI() {
    applyPassportFlightSeriesButtonState(renderState.flightSeries);
  }

  function showEventPanel(event: PassportEvent) {
    renderPassportEventPanel(panel, event, meta, fullEvents);
  }

  renderEmptyPassportPanel(panel);

  const renderer = createPassportRenderer({
    canvas,
    ctx,
    land,
    events,
    meta,
    state: renderState,
    flightSpeed: FLIGHT_SPEED,
    onArrival: (event) => showEventPanel(event),
  });

  // ══════════════════════════════════════════════
  //  INTERACTIONS
  // ══════════════════════════════════════════════

  let isDragging = false;
  let dragStart: [number, number] = [0, 0];
  let rotStart: [number, number, number] = [0, 0, 0];

  // D3 drag behavior for natural globe rotation
  const sensitivity = 0.4;
  const d3Canvas = select(canvas);

  d3Canvas.call(
    drag<HTMLCanvasElement, unknown>()
      .on('start', (event) => {
        isDragging = true;
        renderState.isDragging = true;
        renderState.autoRotate = false;
        renderState.lastInteraction = Date.now();
        renderState.velocityX = 0;
        rotStart = [...renderState.currentRotation] as [number, number, number];
        dragStart = [event.x, event.y];
        canvas.style.cursor = 'grabbing';
      })
      .on('drag', (event) => {
        const dx = event.x - dragStart[0];
        const dy = event.y - dragStart[1];
        renderState.currentRotation[0] = rotStart[0] + dx * sensitivity;
        renderState.currentRotation[1] = Math.max(-60, Math.min(60, rotStart[1] - dy * sensitivity));
        renderState.velocityX = dx * sensitivity * 0.1;
      })
      .on('end', () => {
        isDragging = false;
        renderState.isDragging = false;
        renderState.lastInteraction = Date.now();
        canvas.style.cursor = renderState.hoveredEvent ? 'pointer' : 'grab';
      })
  );

  // Hover
  canvas.addEventListener('mousemove', (e) => {
    if (isDragging) return;
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;

    const best = findNearestProjectedEvent(renderState.projectedDots, mx, my, 18);
    renderState.hoveredEvent = best;
    canvas.style.cursor = best ? 'pointer' : 'grab';

    if (best) {
      tooltip.innerHTML = renderPassportTooltip(best, meta);
      tooltip.style.left = Math.min(mx + 12, rect.width - 260) + 'px';
      tooltip.style.top = (my - 10) + 'px';
      tooltip.classList.remove('hidden');
    } else {
      tooltip.classList.add('hidden');
    }
  });

  canvas.addEventListener('mouseleave', () => {
    renderState.hoveredEvent = null;
    tooltip.classList.add('hidden');
  });

  // Click to select
  canvas.addEventListener('click', (e) => {
    if (isDragging) return;
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const best = findNearestProjectedEvent(renderState.projectedDots, mx, my, 18);
    if (best) {
      renderState.selectedEvent = best;
      showEventPanel(best);
      const pUrl = new URL(window.location.href);
      pUrl.searchParams.set('event', best.id);
      history.replaceState(null, '', pUrl.toString());
    }
  });

  // Touch tap detection
  let touchStart: { x: number; y: number; t: number } | null = null;
  canvas.addEventListener('touchstart', (e) => {
    if (e.touches.length === 1) {
      const rect = canvas.getBoundingClientRect();
      touchStart = {
        x: e.touches[0].clientX - rect.left,
        y: e.touches[0].clientY - rect.top,
        t: Date.now()
      };
    }
  }, { passive: true });

  canvas.addEventListener('touchend', () => {
    if (touchStart && Date.now() - touchStart.t < 300) {
      const mx = touchStart.x, my = touchStart.y;
      const best = findNearestProjectedEvent(renderState.projectedDots, mx, my, 25);
      if (best) {
        renderState.selectedEvent = best;
        showEventPanel(best);
        const pUrl = new URL(window.location.href);
        pUrl.searchParams.set('event', best.id);
        history.replaceState(null, '', pUrl.toString());
      }
    }
    touchStart = null;
  }, { passive: true });

  // Zoom
  canvas.addEventListener('wheel', (e) => {
    e.preventDefault();
    renderState.scaleFactor *= e.deltaY > 0 ? 0.95 : 1.05;
    renderState.scaleFactor = Math.max(0.5, Math.min(3, renderState.scaleFactor));
    renderState.lastInteraction = Date.now();
    renderState.autoRotate = false;
  }, { passive: false });

  document.getElementById('globe-zoom-in')!.addEventListener('click', () => {
    renderState.scaleFactor = Math.min(3, renderState.scaleFactor * 1.15);
    renderState.lastInteraction = Date.now();
  });
  document.getElementById('globe-zoom-out')!.addEventListener('click', () => {
    renderState.scaleFactor = Math.max(0.5, renderState.scaleFactor * 0.85);
    renderState.lastInteraction = Date.now();
  });
  document.getElementById('globe-reset')!.addEventListener('click', () => {
    renderState.scaleFactor = 1;
    renderState.currentRotation = [0, -20, 0];
    renderState.autoRotate = true;
    renderState.velocityX = 0;
    renderState.selectedEvent = null;
    renderState.flightProgress = 0;
    renderState.flightPaused = false;
    // Reset pause button UI
    document.getElementById('pause-icon')?.classList.remove('hidden');
    document.getElementById('play-icon')?.classList.add('hidden');
    renderEmptyPassportPanel(panel);
    // Clear event from URL
    const rUrl = new URL(window.location.href);
    rUrl.searchParams.delete('event');
    history.replaceState(null, '', rUrl.toString());
  });

  // ══════════════════════════════════════════════
  //  FILTERS + STATS
  // ══════════════════════════════════════════════

  document.querySelectorAll('.passport-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter!;
      renderState.activeFilter = filter;
      renderState.selectedEvent = null;
      renderEmptyPassportPanel(panel);
      // Clear event from URL when filter changes
      const fUrl = new URL(window.location.href);
      fUrl.searchParams.delete('event');
      history.replaceState(null, '', fUrl.toString());

      applyPassportFilterButtonState(filter);

      // When filtering to a specific series that is flightable, auto-switch the flight route
      if (filter !== 'all' && flightableIds.includes(filter)) {
        setFlightSeries(filter);
      }
      updateFlightState();
      updateStats();
    });
  });

  // Flight series selector buttons
  document.querySelectorAll<HTMLElement>('.flight-series-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const sid = btn.dataset.flightSeries!;
      setFlightSeries(sid);
    });
  });

  // ── Init ──
  updateStats();
  updateFlightState();
  updateFlightSeriesUI();

  // Pause/play button
  document.getElementById('globe-pause')!.addEventListener('click', () => {
    renderState.flightPaused = !renderState.flightPaused;
    const pauseIcon = document.getElementById('pause-icon')!;
    const playIcon = document.getElementById('play-icon')!;
    if (renderState.flightPaused) {
      pauseIcon.classList.add('hidden');
      playIcon.classList.remove('hidden');
    } else {
      pauseIcon.classList.remove('hidden');
      playIcon.classList.add('hidden');
    }
  });

  // Follow plane toggle
  const followBtn = document.getElementById('globe-follow')!;
  followBtn.addEventListener('click', () => {
    renderState.followPlane = !renderState.followPlane;
    if (renderState.followPlane) {
      followBtn.classList.remove('text-zinc-400');
      followBtn.classList.add('text-emerald-400');
      renderState.autoRotate = false;
    } else {
      followBtn.classList.remove('text-emerald-400');
      followBtn.classList.add('text-zinc-400');
    }
  });

  renderer.start();
  document.addEventListener('astro:before-swap', () => renderer.stop());

  // ── Deeplink: focus globe on event from ?event= param ──
  (function resolvePassportDeeplink() {
    const eventId = new URLSearchParams(window.location.search).get('event');
    if (!eventId) return;
    const ev = events.find((e) => e.id === eventId);
    if (ev) {
      renderState.selectedEvent = ev;
      showEventPanel(ev);
      // Rotate globe to centre on this event
      renderState.currentRotation = [-ev.lng, -ev.lat, 0];
      renderState.autoRotate = false;
    }
  })();
</script>
