---
import Layout from '../layouts/Layout.astro';
import type { EventFeed } from '../lib/types';
import calendarData from '../../data/gold/calendar.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const events = (calendarData as EventFeed).events;
const totalSeries = new Set(events.map((e) => e.seriesId)).size;

// Build heatmap data: session count per day for the entire year
const heatmapYear = 2026;
const heatmapStart = new Date(heatmapYear, 0, 1); // Jan 1
const heatmapEnd = new Date(heatmapYear, 11, 31); // Dec 31

// Count sessions per day
const daySessions = new Map<string, { count: number; labels: string[] }>();
for (const event of events) {
  for (const session of event.sessions) {
    if (session.startTimeUTC.startsWith('1900-')) continue;
    const dayKey = session.startTimeUTC.slice(0, 10); // YYYY-MM-DD
    if (!daySessions.has(dayKey)) daySessions.set(dayKey, { count: 0, labels: [] });
    const entry = daySessions.get(dayKey)!;
    entry.count++;
    if (entry.labels.length < 5) entry.labels.push(`${event.seriesId.toUpperCase()} ${session.type}`);
  }
}

// Build day array from Jan 1 to Dec 31
interface HeatDay { date: string; count: number; labels: string[]; month: number; }
const heatDays: HeatDay[] = [];
const cursor = new Date(heatmapStart);
while (cursor <= heatmapEnd) {
  const key = cursor.toISOString().slice(0, 10);
  const entry = daySessions.get(key) ?? { count: 0, labels: [] };
  heatDays.push({ date: key, count: entry.count, labels: entry.labels, month: cursor.getMonth() });
  cursor.setDate(cursor.getDate() + 1);
}

// Pad start to align with Monday
const firstDow = (new Date(heatmapStart).getDay() + 6) % 7; // 0=Mon
const paddedDays: (HeatDay | null)[] = [...Array(firstDow).fill(null), ...heatDays];
const maxCount = Math.max(1, ...heatDays.map(d => d.count));

// Month labels (first day of each month's column)
const monthLabels: { label: string; col: number }[] = [];
let prevMonth = -1;
for (let i = 0; i < paddedDays.length; i++) {
  const d = paddedDays[i];
  if (d && d.month !== prevMonth) {
    const col = Math.floor(i / 7);
    monthLabels.push({ label: new Date(d.date + 'T12:00:00Z').toLocaleDateString('en', { month: 'short' }), col });
    prevMonth = d.month;
  }
}

const totalWeeks = Math.ceil(paddedDays.length / 7);
const todayKey = new Date().toISOString().slice(0, 10);
---

<Layout title="RaceTrack — Calendar" currentPath={`${base}/calendar`}>
  <main class="max-w-5xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="mb-6 flex items-end justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-bold mb-1">2026 Calendar</h1>
        <p class="text-zinc-400 text-sm">{events.length} events · {totalSeries} series</p>
      </div>
      <button
        id="cal-today-btn"
        class="text-xs text-zinc-400 border border-zinc-700 hover:border-zinc-500 hover:text-zinc-200 transition-colors rounded-lg px-3 py-1.5"
      >
        Today
      </button>
    </div>

    <!-- Category quick-select + series filter pills -->
    <div class="mb-5 space-y-2">
      <div id="cal-cat-filter" class="flex flex-wrap gap-1.5 items-center">
        <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mr-1">View</span>
      </div>
      <div id="cal-filter" class="flex flex-wrap gap-1.5"></div>
    </div>

    <!-- Season Heatmap -->
    <div class="mb-6">
      <h3 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2">Season Activity</h3>
      <div class="overflow-x-auto pb-2">
        <div class="inline-grid gap-[2px]" style={`grid-template-columns: repeat(${totalWeeks}, 1fr); grid-template-rows: repeat(7, 1fr);`}>
          {(() => {
            const cells: any[] = [];
            for (let week = 0; week < totalWeeks; week++) {
              for (let dow = 0; dow < 7; dow++) {
                const idx = week * 7 + dow;
                const day = paddedDays[idx] ?? null;
                if (!day) {
                  cells.push(<div class="w-[11px] h-[11px]" />);
                } else {
                  const intensity = day.count === 0 ? 0 : Math.min(1, day.count / maxCount);
                  const opacity = day.count === 0 ? 0.06 : 0.15 + intensity * 0.85;
                  const isToday = day.date === todayKey;
                  const title = day.count === 0
                    ? day.date
                    : `${day.count} session${day.count !== 1 ? 's' : ''} on ${day.date}: ${day.labels.join(', ')}`;
                  cells.push(
                    <div
                      class={`w-[11px] h-[11px] rounded-[2px] ${isToday ? 'ring-1 ring-zinc-400' : ''}`}
                      style={`background-color: rgba(99, 102, 241, ${opacity});`}
                      title={title}
                    />
                  );
                }
              }
            }
            return cells;
          })()}
        </div>
        <div class="flex gap-0 mt-1" style={`width: ${totalWeeks * 13}px;`}>
          {monthLabels.map(m => (
            <span
              class="text-[8px] text-zinc-600 absolute"
              style={`position: relative; left: ${m.col * 13}px;`}
            >
              {m.label}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Month navigation -->
    <div class="flex items-center gap-3 mb-3">
      <button
        id="cal-prev"
        class="w-8 h-8 rounded-lg border border-zinc-700 hover:border-zinc-500 hover:bg-zinc-800 transition-colors flex items-center justify-center text-zinc-400 hover:text-zinc-200 shrink-0"
        aria-label="Previous month"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      <h2 id="cal-month-label" class="text-base font-bold text-zinc-100 flex-1 text-center"></h2>
      <button
        id="cal-next"
        class="w-8 h-8 rounded-lg border border-zinc-700 hover:border-zinc-500 hover:bg-zinc-800 transition-colors flex items-center justify-center text-zinc-400 hover:text-zinc-200 shrink-0"
        aria-label="Next month"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>

    <!-- Day-of-week headers -->
    <div class="grid grid-cols-7 mb-px">
      {['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].map(d => (
        <div class="text-center text-[10px] font-semibold uppercase tracking-widest text-zinc-700 py-2">{d}</div>
      ))}
    </div>

    <!-- Calendar grid (filled by JS) -->
    <div
      id="cal-grid"
      class="grid grid-cols-7 gap-px bg-zinc-800/40 rounded-xl overflow-hidden border border-zinc-800/60"
    ></div>

    <!-- Selected day detail panel (filled by JS) -->
    <div id="cal-day-detail"></div>

    <!-- All event data for client-side rendering -->
    <script id="all-events-data" type="application/json" set:html={JSON.stringify(events)} is:inline />
  </main>
</Layout>

<script>
  import { openEventById, registerEvents } from '../lib/event-client';
  import { SESSION_ABBR, isRaceType } from '../lib/sessions';
  import { SERIES_META, SERIES_ORDER } from '../lib/series-client';
  import { getSeriesMeta } from '../lib/series';
  import { countryFlag, escapeHtml, formatLocalTime, isPastEvent, safeJsonParse } from '../lib/client-utils';
  import { downloadShareCardForDates } from '../lib/share-card';
  import { loadFilters, saveFilters } from '../lib/filters';
  import type { RaceEvent, RaceSession } from '../lib/types';

  // ── Data & series meta ────────────────────────────────────────────────────
  const allEvents: RaceEvent[] = safeJsonParse(document.getElementById('all-events-data')!.textContent!, []);
  registerEvents(allEvents);

  const allSeriesIds = [...new Set<string>(allEvents.map(e => e.seriesId))];

  // ── State ─────────────────────────────────────────────────────────────────
  const todayDate = new Date();
  todayDate.setHours(0, 0, 0, 0);
  let displayYear  = todayDate.getFullYear();
  let displayMonth = todayDate.getMonth(); // 0-based
  const selectedDates = new Set<string>();
  let lastSelectedDate: string | null = null;

  // empty set = all visible (same convention as dashboard filter)
  const activeFilters = new Set<string>();

  function loadFiltersFromStorage() {
    const loaded = loadFilters();
    activeFilters.clear();
    for (const id of loaded) {
      if (allSeriesIds.includes(id)) activeFilters.add(id);
    }
  }

  function saveFiltersToStorage() {
    saveFilters(activeFilters);
    rebuildDateIndex();
  }

  // ── Helpers ───────────────────────────────────────────────────────────────
  function toDateStr(d: Date): string {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  // Monday-based day of week: 0=Mon … 6=Sun
  function monDow(d: Date): number {
    return (d.getDay() + 6) % 7;
  }

  function eventsOnDate(dateStr: string): RaceEvent[] {
    return dateIndex.get(dateStr) ?? [];
  }

  function getSelectedDates(): string[] {
    return [...selectedDates].sort();
  }

  function formatSelectionLabel(dateStrings: string[]): string {
    if (dateStrings.length === 0) return '';
    if (dateStrings.length === 1) {
      return new Date(dateStrings[0] + 'T12:00:00').toLocaleDateString('en', {
        weekday: 'long', month: 'long', day: 'numeric',
      });
    }
    const first = new Date(dateStrings[0] + 'T12:00:00');
    const last = new Date(dateStrings[dateStrings.length - 1] + 'T12:00:00');
    return `${dateStrings.length} days · ${first.toLocaleDateString('en', { month: 'short', day: 'numeric' })}–${last.toLocaleDateString('en', { month: 'short', day: 'numeric' })}`;
  }

  function getDatesBetween(startStr: string, endStr: string): string[] {
    const start = new Date(startStr + 'T12:00:00');
    const end = new Date(endStr + 'T12:00:00');
    const from = start <= end ? start : end;
    const to = start <= end ? end : start;
    const dates: string[] = [];
    for (const cursor = new Date(from); cursor <= to; cursor.setDate(cursor.getDate() + 1)) {
      dates.push(toDateStr(cursor));
    }
    return dates;
  }

  function updateSelection(dateStr: string, event?: MouseEvent) {
    if (event?.shiftKey && lastSelectedDate) {
      selectedDates.clear();
      getDatesBetween(lastSelectedDate, dateStr).forEach(date => selectedDates.add(date));
      lastSelectedDate = dateStr;
      return;
    }

    if (event?.metaKey || event?.ctrlKey) {
      if (selectedDates.has(dateStr)) selectedDates.delete(dateStr);
      else selectedDates.add(dateStr);
      lastSelectedDate = selectedDates.size > 0 ? dateStr : null;
      return;
    }

    if (selectedDates.size === 1 && selectedDates.has(dateStr)) {
      selectedDates.clear();
      lastSelectedDate = null;
      return;
    }

    selectedDates.clear();
    selectedDates.add(dateStr);
    lastSelectedDate = dateStr;
  }

  function sessionsOnDay(ev: RaceEvent, dateStr: string): RaceSession[] {
    return (ev.sessions ?? []).filter((s) => {
      if (s.startTimeUTC.startsWith('1900')) return false;
      return s.startTimeUTC.slice(0, 10) === dateStr || new Date(s.startTimeUTC).toLocaleDateString('en-CA') === dateStr;
    });
  }

  // Build a Map<dateStr, Event[]> index for O(1) lookup per calendar cell
  let dateIndex = new Map<string, RaceEvent[]>();

  function rebuildDateIndex() {
    dateIndex = new Map();
    const showAll = activeFilters.size === 0;
    for (const e of allEvents) {
      if (!showAll && !activeFilters.has(e.seriesId)) continue;
      // Walk from dateStart to dateEnd
      const start = new Date(e.dateStart + 'T12:00:00Z');
      const end = new Date(e.dateEnd + 'T12:00:00Z');
      for (let d = new Date(start); d <= end; d.setUTCDate(d.getUTCDate() + 1)) {
        const key = d.toISOString().slice(0, 10);
        const arr = dateIndex.get(key);
        if (arr) arr.push(e);
        else dateIndex.set(key, [e]);
      }
    }
  }

  // ── Filter UI ─────────────────────────────────────────────────────────────
  function renderFilter() {
    const showAll = activeFilters.size === 0;
    const seriesInData = SERIES_ORDER.filter(id => allSeriesIds.includes(id));
    const fourWheelIds = seriesInData.filter(id => SERIES_META[id]?.category === '4-wheel');
    const twoWheelIds  = seriesInData.filter(id => SERIES_META[id]?.category === '2-wheel');

    // ── Category buttons ──
    const catContainer = document.getElementById('cal-cat-filter')!;
    const catDefs = [
      { key: 'all',     label: 'All',        ids: seriesInData },
      { key: '4-wheel', label: '🚗 4-Wheel', ids: fourWheelIds },
      { key: '2-wheel', label: '🏍 2-Wheel', ids: twoWheelIds  },
    ];

    // Keep the label span, re-render only buttons
    const existingBtns = catContainer.querySelectorAll('.cal-cat-btn');
    if (existingBtns.length === 0) {
      catContainer.insertAdjacentHTML('beforeend', catDefs.map(({ key, label }) =>
        `<button class="cal-cat-btn text-xs px-3 py-1 rounded-full border font-semibold transition-all duration-150 select-none" data-cat="${key}">${label}</button>`
      ).join(''));

      catContainer.querySelectorAll<HTMLButtonElement>('.cal-cat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const cat = btn.dataset.cat!;
          if (cat === 'all') {
            activeFilters.clear();
          } else {
            const ids = cat === '4-wheel' ? fourWheelIds : twoWheelIds;
            const allSelected = ids.every(id => activeFilters.has(id));
            const isExclusive = allSelected && [...activeFilters].every(id => ids.includes(id));
            if (isExclusive) {
              activeFilters.clear();
            } else {
              activeFilters.clear();
              ids.forEach(id => activeFilters.add(id));
            }
          }
          selectedDates.clear();
          lastSelectedDate = null;
          saveFiltersToStorage();
          renderFilter();
          renderMonth();
          renderDayDetail();
        });
      });
    }

    // Style category buttons
    catContainer.querySelectorAll<HTMLButtonElement>('.cal-cat-btn').forEach(btn => {
      const cat = btn.dataset.cat!;
      let state: 'active' | 'partial' | 'inactive';
      if (cat === 'all') {
        state = showAll ? 'active' : 'inactive';
      } else {
        const ids = cat === '4-wheel' ? fourWheelIds : twoWheelIds;
        if (showAll || ids.every(id => activeFilters.has(id))) {
          const isExclusive = !showAll && [...activeFilters].every(id => ids.includes(id));
          state = isExclusive ? 'active' : 'partial';
        } else {
          state = ids.some(id => activeFilters.has(id)) ? 'partial' : 'inactive';
        }
      }
      if (state === 'active') {
        btn.style.cssText = 'background-color:#27272a;border-color:#71717a;color:#f4f4f5';
      } else if (state === 'partial') {
        btn.style.cssText = 'background-color:#1c1c1e;border-color:#52525b;color:#a1a1aa';
      } else {
        btn.style.cssText = 'background-color:transparent;border-color:#3f3f46;color:#52525b';
      }
    });

    // ── Individual series chips ──
    const container = document.getElementById('cal-filter')!;
    container.innerHTML = seriesInData.map((id, i) => {
      const m = getSeriesMeta(id);
      const on = showAll || activeFilters.has(id);
      const style = on
        ? `background-color:${m.color}20;border-color:${m.color}60;color:${m.color}`
        : 'background-color:transparent;border-color:#3f3f46;color:#52525b';
      // Add visual divider before first 2-wheel series
      const divider = (i > 0 && m.category === '2-wheel' && getSeriesMeta(seriesInData[i - 1]).category === '4-wheel')
        ? '<span class="h-4 w-px bg-zinc-700/60 self-center mx-0.5" aria-hidden="true"></span>'
        : '';
      return `${divider}<button class="cal-filter-btn text-xs font-bold px-2.5 py-1 rounded-full border transition-all duration-150 select-none" data-series="${id}" style="${style}">
        <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background-color:${m.color};margin-right:3px;vertical-align:middle"></span>${m.shortLabel}
      </button>`;
    }).join('');

    container.querySelectorAll<HTMLButtonElement>('.cal-filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.series!;
        if (activeFilters.has(id)) {
          activeFilters.delete(id);
        } else {
          // If currently showing all, switch to "all except this one" when deselecting
          if (showAll) {
            allSeriesIds.forEach(s => { if (s !== id) activeFilters.add(s); });
          } else {
            activeFilters.add(id);
          }
        }
        selectedDates.clear();
        lastSelectedDate = null;
        saveFiltersToStorage();
        renderFilter();
        renderMonth();
        renderDayDetail();
      });
    });
  }

  // ── Month grid ────────────────────────────────────────────────────────────
  function renderMonth() {
    const grid  = document.getElementById('cal-grid')!;
    const label = document.getElementById('cal-month-label')!;

    label.textContent = new Date(displayYear, displayMonth, 1)
      .toLocaleDateString('en', { month: 'long', year: 'numeric' });

    const firstDay  = new Date(displayYear, displayMonth, 1);
    const totalDays = new Date(displayYear, displayMonth + 1, 0).getDate();
    const startOffset = monDow(firstDay); // leading blank cells
    const todayStr  = toDateStr(todayDate);
    const cells: string[] = [];

    // Leading empty cells
    for (let i = 0; i < startOffset; i++) {
      cells.push('<div class="bg-zinc-950 min-h-[76px] sm:min-h-[96px]"></div>');
    }

    for (let day = 1; day <= totalDays; day++) {
      const dateStr  = `${displayYear}-${String(displayMonth + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const isToday  = dateStr === todayStr;
      const isPast   = dateStr < todayStr;
      const isSel    = selectedDates.has(dateStr);
      const evs      = eventsOnDate(dateStr);

      // Deduplicate: one badge per series per day
      const seenSeries = new Set<string>();
      const uniqueEvs = evs.filter(e => {
        if (seenSeries.has(e.seriesId)) return false;
        seenSeries.add(e.seriesId);
        return true;
      });

      const MAX_BADGES = 3;
      const visible  = uniqueEvs.slice(0, MAX_BADGES);
      const overflow = uniqueEvs.length - MAX_BADGES;

      const badgesHtml = visible.map(e => {
        const m = getSeriesMeta(e.seriesId);
        const isRaceDay = e.dateEnd === dateStr;
        const bg   = isRaceDay ? m.color + 'ee' : m.color + '28';
        const text = isRaceDay ? '#ffffff' : m.color;
        return `<span
          class="shrink-0 text-[9px] font-bold leading-none rounded px-1 py-0.5 whitespace-nowrap block"
          style="background-color:${bg};color:${text}"
          title="${escapeHtml(e.eventName)}"
        >${m.shortLabel}</span>`;
      }).join('');

      const overflowHtml = overflow > 0
        ? `<span class="text-[9px] text-zinc-600 font-medium leading-none">+${overflow}</span>`
        : '';

      // Clash badge — 3+ unique series on same day
      const clashHtml = seenSeries.size >= 3
        ? `<span class="text-[9px] font-bold text-amber-400 leading-none" title="${seenSeries.size} series racing">⚡</span>`
        : '';

      const dayNumClass = isToday
        ? 'w-5 h-5 sm:w-6 sm:h-6 rounded-full flex items-center justify-center bg-emerald-500 text-zinc-950 font-black text-[10px] sm:text-xs leading-none'
        : isPast
          ? 'text-xs sm:text-sm font-medium text-zinc-700 leading-none'
          : 'text-xs sm:text-sm font-medium text-zinc-300 leading-none';

      const cellBase = 'cal-day relative bg-zinc-950 transition-colors cursor-pointer min-h-[76px] sm:min-h-[96px] p-1.5 sm:p-2';
      const cellState = isSel
        ? 'ring-1 ring-inset ring-zinc-500 bg-zinc-900/80 hover:bg-zinc-900'
        : 'hover:bg-zinc-900/60';

      cells.push(`<div class="${cellBase} ${cellState}" data-date="${dateStr}" role="button" tabindex="0" aria-label="${dateStr}${evs.length > 0 ? `, ${evs.length} event${evs.length > 1 ? 's' : ''}` : ''}">
        <div class="flex items-start justify-between mb-1">
          <span class="${dayNumClass}">${day}</span>
        </div>
        <div class="flex flex-wrap gap-0.5 sm:gap-1">
          ${badgesHtml}${overflowHtml}${clashHtml}
        </div>
      </div>`);
    }

    // Trailing empty cells to fill last row
    const used = startOffset + totalDays;
    const trail = (7 - (used % 7)) % 7;
    for (let i = 0; i < trail; i++) {
      cells.push('<div class="bg-zinc-950 min-h-[76px] sm:min-h-[96px]"></div>');
    }

    grid.innerHTML = cells.join('');

    grid.querySelectorAll<HTMLElement>('.cal-day').forEach(cell => {
      cell.addEventListener('click', (event) => {
        const d = cell.dataset.date!;
        updateSelection(d, event as MouseEvent);
        renderMonth();
        renderDayDetail();
      });
      cell.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); cell.click(); }
      });
    });
  }

  // ── Day detail panel ──────────────────────────────────────────────────────
  function renderDayDetail() {
    const panel = document.getElementById('cal-day-detail')!;
    const dateStrings = getSelectedDates();

    if (dateStrings.length === 0) { panel.innerHTML = ''; return; }

    const daySections = dateStrings.map(dateStr => {
      const dayEvs = eventsOnDate(dateStr);
      if (dayEvs.length === 0) return '';
      const dateLabel = new Date(dateStr + 'T12:00:00').toLocaleDateString('en', {
        weekday: 'long', month: 'long', day: 'numeric',
      });

      const cardsHtml = dayEvs.map(ev => {
        const m = getSeriesMeta(ev.seriesId);
        const sessions = sessionsOnDay(ev, dateStr);
        const f = countryFlag(ev.circuit?.countryCode ?? '');
        const isRaceDay = ev.dateEnd === dateStr;
        const past = isPastEvent(ev.dateEnd, ev.sessions ?? []);
        const isFirstDay = ev.dateStart === dateStr;

        const sessHtml = sessions.map((s: any) => {
          const lbl = SESSION_ABBR[s.type] ?? s.type;
          const isRace = isRaceType(s.type);
          const t = formatLocalTime(s.startTimeUTC);
          return `<div class="flex items-center gap-1.5 text-xs">
            <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background-color:${isRace ? m.color : '#3f3f46'}"></span>
            <span class="font-semibold ${isRace ? 'text-zinc-100' : 'text-zinc-400'}">${lbl}</span>
            <span class="tabular-nums text-zinc-600">${t}</span>
          </div>`;
        }).join('');

        const spanLabel = ev.dateStart === ev.dateEnd
          ? ''
          : isFirstDay
            ? `<span class="text-[10px] text-zinc-600">Weekend starts</span>`
            : isRaceDay
              ? `<span class="text-[10px] font-bold uppercase tracking-wider" style="color:${m.color}">Race day</span>`
              : `<span class="text-[10px] text-zinc-600">Race weekend</span>`;

        return `<article
          class="cal-detail-card flex gap-3 p-3 rounded-xl border cursor-pointer transition-colors ${past ? 'border-zinc-800/40 bg-zinc-900/20 opacity-50' : 'border-zinc-800 bg-zinc-900 hover:border-zinc-700'}"
          data-event-id="${escapeHtml(ev.id)}"
          role="button" tabindex="0"
        >
          <div class="w-0.5 self-stretch rounded-full shrink-0" style="background-color:${m.color}"></div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1 flex-wrap">
              <span class="text-xs font-bold px-2 py-0.5 rounded text-white uppercase tracking-wide" style="background-color:${m.color}">${m.shortLabel}</span>
              <span class="text-[11px] text-zinc-500 font-mono">Rd ${ev.round}</span>
              ${spanLabel}
            </div>
            <h3 class="font-bold text-sm ${past ? 'text-zinc-500' : 'text-zinc-100'} mb-1">${escapeHtml(ev.eventName)}</h3>
            <div class="flex items-center gap-1.5 text-xs text-zinc-500 ${sessions.length > 0 ? 'mb-2' : ''}">
              ${f ? `<span class="text-sm">${f}</span>` : ''}<span>${escapeHtml(ev.circuit?.name ?? '')}</span>
            </div>
            ${sessions.length > 0 ? `<div class="flex flex-wrap gap-x-3 gap-y-1">${sessHtml}</div>` : ''}
          </div>
        </article>`;
      }).join('');

      return `
        <section class="grid gap-2">
          ${dateStrings.length > 1 ? `<div class="px-1 text-[11px] font-semibold uppercase tracking-widest text-zinc-600">${dateLabel}</div>` : ''}
          <div class="grid gap-2 sm:grid-cols-2">${cardsHtml}</div>
        </section>
      `;
    }).filter(Boolean).join('');

    if (!daySections) { panel.innerHTML = ''; return; }

    panel.innerHTML = `
      <div class="mt-3 border border-zinc-800 rounded-xl overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-zinc-800 bg-zinc-900/40">
          <div class="min-w-0">
            <span class="font-semibold text-sm text-zinc-200">${formatSelectionLabel(dateStrings)}</span>
            <p class="text-[10px] uppercase tracking-widest text-zinc-600 mt-1">Click a day to replace. Cmd/Ctrl-click to add. Shift-click for a range.</p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <button id="cal-share-btn" class="inline-flex items-center gap-1.5 rounded-full border border-zinc-800 bg-zinc-900/70 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-zinc-400 transition hover:border-zinc-700 hover:text-zinc-200" type="button">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V4.5m0 12 4.5-4.5M12 16.5l-4.5-4.5M4.5 19.5h15" />
              </svg>
              <span id="cal-share-btn-label">Share PNG</span>
            </button>
            <button id="cal-detail-close" class="text-zinc-600 hover:text-zinc-300 transition-colors p-1" aria-label="Close">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        </div>
        <div class="p-3 grid gap-3">
          ${daySections}
        </div>
      </div>
    `;

    document.getElementById('cal-detail-close')!.addEventListener('click', () => {
      selectedDates.clear();
      lastSelectedDate = null;
      renderMonth();
      renderDayDetail();
    });

    document.getElementById('cal-share-btn')!.addEventListener('click', () => {
      const btn = document.getElementById('cal-share-btn') as HTMLButtonElement;
      const label = document.getElementById('cal-share-btn-label') as HTMLElement;
      btn.disabled = true;
      label.textContent = 'Preparing';
      try {
        const downloaded = downloadShareCardForDates(allEvents, dateStrings);
        label.textContent = downloaded ? 'Saved' : 'Unavailable';
      } catch {
        label.textContent = 'Try again';
      } finally {
        window.setTimeout(() => {
          btn.disabled = false;
          label.textContent = 'Share PNG';
        }, 900);
      }
    });

    panel.querySelectorAll<HTMLElement>('.cal-detail-card').forEach(card => {
      card.addEventListener('click', () => {
        const eventId = card.dataset.eventId;
        if (eventId) openEventById(eventId);
      });
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
      });
    });

    // Scroll detail panel into view smoothly
    panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ── Month navigation ──────────────────────────────────────────────────────
  document.getElementById('cal-prev')!.addEventListener('click', () => {
    if (--displayMonth < 0) { displayMonth = 11; displayYear--; }
    selectedDates.clear();
    lastSelectedDate = null;
    renderMonth();
    renderDayDetail();
  });

  document.getElementById('cal-next')!.addEventListener('click', () => {
    if (++displayMonth > 11) { displayMonth = 0; displayYear++; }
    selectedDates.clear();
    lastSelectedDate = null;
    renderMonth();
    renderDayDetail();
  });

  document.getElementById('cal-today-btn')!.addEventListener('click', () => {
    displayYear  = todayDate.getFullYear();
    displayMonth = todayDate.getMonth();
    selectedDates.clear();
    lastSelectedDate = null;
    renderMonth();
    renderDayDetail();
  });

  // ── Bootstrap ─────────────────────────────────────────────────────────────
  function init() {
    loadFiltersFromStorage();
    rebuildDateIndex();
    renderFilter();
    renderMonth();
    renderDayDetail();
  }

  // Sync when filter changes on another page (e.g. dashboard)
  window.addEventListener('rt-filters-changed', (e: any) => {
    const ids: string[] = e.detail.active ?? [];
    activeFilters.clear();
    ids.forEach((id: string) => { if (allSeriesIds.includes(id)) activeFilters.add(id); });
    rebuildDateIndex();
    selectedDates.clear();
    lastSelectedDate = null;
    renderFilter();
    renderMonth();
    renderDayDetail();
  });

  init();
  document.addEventListener('astro:after-swap', init);
</script>
