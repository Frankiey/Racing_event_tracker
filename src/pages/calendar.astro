---
import Layout from '../layouts/Layout.astro';
import calendarData from '../../data/gold/calendar.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const events = calendarData as any[];
const totalSeries = new Set(events.map((e: any) => e.seriesId)).size;
---

<Layout title="RaceTrack — Calendar" currentPath={`${base}/calendar`}>
  <main class="max-w-5xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="mb-6 flex items-end justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-2xl font-bold mb-1">2026 Calendar</h1>
        <p class="text-zinc-400 text-sm">{events.length} events · {totalSeries} series</p>
      </div>
      <button
        id="cal-today-btn"
        class="text-xs text-zinc-400 border border-zinc-700 hover:border-zinc-500 hover:text-zinc-200 transition-colors rounded-lg px-3 py-1.5"
      >
        Today
      </button>
    </div>

    <!-- Category quick-select + series filter pills -->
    <div class="mb-5 space-y-2">
      <div id="cal-cat-filter" class="flex flex-wrap gap-1.5 items-center">
        <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mr-1">View</span>
      </div>
      <div id="cal-filter" class="flex flex-wrap gap-1.5"></div>
    </div>

    <!-- Month navigation -->
    <div class="flex items-center gap-3 mb-3">
      <button
        id="cal-prev"
        class="w-8 h-8 rounded-lg border border-zinc-700 hover:border-zinc-500 hover:bg-zinc-800 transition-colors flex items-center justify-center text-zinc-400 hover:text-zinc-200 shrink-0"
        aria-label="Previous month"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
      <h2 id="cal-month-label" class="text-base font-bold text-zinc-100 flex-1 text-center"></h2>
      <button
        id="cal-next"
        class="w-8 h-8 rounded-lg border border-zinc-700 hover:border-zinc-500 hover:bg-zinc-800 transition-colors flex items-center justify-center text-zinc-400 hover:text-zinc-200 shrink-0"
        aria-label="Next month"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>

    <!-- Day-of-week headers -->
    <div class="grid grid-cols-7 mb-px">
      {['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].map(d => (
        <div class="text-center text-[10px] font-semibold uppercase tracking-widest text-zinc-700 py-2">{d}</div>
      ))}
    </div>

    <!-- Calendar grid (filled by JS) -->
    <div
      id="cal-grid"
      class="grid grid-cols-7 gap-px bg-zinc-800/40 rounded-xl overflow-hidden border border-zinc-800/60"
    ></div>

    <!-- Selected day detail panel (filled by JS) -->
    <div id="cal-day-detail"></div>

    <!-- All event data for client-side rendering -->
    <script id="all-events-data" type="application/json" set:html={JSON.stringify(events)} />
  </main>
</Layout>

<script>
  // ── Data & series meta ────────────────────────────────────────────────────
  const allEvents: any[] = JSON.parse(document.getElementById('all-events-data')!.textContent!);

  const FILTER_KEY = 'rt-filters';

  const SERIES_ORDER = ['f1','f2','f3','fe','motogp','moto2','moto3','indycar','nascar','wec'];
  const SERIES_META: Record<string, { label: string; shortLabel: string; color: string; category: '4-wheel' | '2-wheel' }> = {
    f1:      { label: 'Formula 1',  shortLabel: 'F1',      color: '#e10600', category: '4-wheel' },
    f2:      { label: 'Formula 2',  shortLabel: 'F2',      color: '#0090d0', category: '4-wheel' },
    f3:      { label: 'Formula 3',  shortLabel: 'F3',      color: '#60a5fa', category: '4-wheel' },
    fe:      { label: 'Formula E',  shortLabel: 'FE',      color: '#14b8a6', category: '4-wheel' },
    motogp:  { label: 'MotoGP',     shortLabel: 'MotoGP',  color: '#be123c', category: '2-wheel' },
    moto2:   { label: 'Moto2',      shortLabel: 'Moto2',   color: '#f97316', category: '2-wheel' },
    moto3:   { label: 'Moto3',      shortLabel: 'Moto3',   color: '#facc15', category: '2-wheel' },
    indycar: { label: 'IndyCar',    shortLabel: 'IndyCar', color: '#1e40af', category: '4-wheel' },
    nascar:  { label: 'NASCAR',     shortLabel: 'NASCAR',  color: '#eab308', category: '4-wheel' },
    wec:     { label: 'WEC',        shortLabel: 'WEC',     color: '#0ea5e9', category: '4-wheel' },
  };

  // ── State ─────────────────────────────────────────────────────────────────
  const todayDate = new Date();
  todayDate.setHours(0, 0, 0, 0);
  let displayYear  = todayDate.getFullYear();
  let displayMonth = todayDate.getMonth(); // 0-based
  let selectedDate: string | null = null;

  const allSeriesIds = [...new Set<string>(allEvents.map(e => e.seriesId))];

  // empty set = all visible (same convention as dashboard filter)
  const activeFilters = new Set<string>();

  function loadFiltersFromStorage() {
    try {
      const raw = localStorage.getItem(FILTER_KEY);
      if (raw) {
        const arr = JSON.parse(raw);
        if (Array.isArray(arr) && arr.length > 0) {
          activeFilters.clear();
          arr.forEach((id: string) => { if (allSeriesIds.includes(id)) activeFilters.add(id); });
          return;
        }
      }
    } catch {}
    activeFilters.clear(); // empty = all
  }

  function saveFiltersToStorage() {
    if (activeFilters.size === 0) {
      localStorage.removeItem(FILTER_KEY);
    } else {
      localStorage.setItem(FILTER_KEY, JSON.stringify([...activeFilters]));
    }
    window.dispatchEvent(new CustomEvent('rt-filters-changed', { detail: { active: [...activeFilters] } }));
  }

  // ── Helpers ───────────────────────────────────────────────────────────────
  function toDateStr(d: Date): string {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  // Monday-based day of week: 0=Mon … 6=Sun
  function monDow(d: Date): number {
    return (d.getDay() + 6) % 7;
  }

  function eventsOnDate(dateStr: string): any[] {
    const showAll = activeFilters.size === 0;
    return allEvents.filter(e =>
      (showAll || activeFilters.has(e.seriesId)) &&
      e.dateStart <= dateStr &&
      e.dateEnd   >= dateStr
    );
  }

  function flag(code: string): string {
    if (!code || code.length !== 2) return '';
    const base = 0x1F1E6 - 0x41;
    return String.fromCodePoint(
      code.toUpperCase().charCodeAt(0) + base,
      code.toUpperCase().charCodeAt(1) + base
    );
  }

  function fmtTime(utc: string): string {
    return new Date(utc).toLocaleTimeString(undefined, {
      hour: '2-digit', minute: '2-digit', hour12: false,
    });
  }

  const SESSION_ABBR: Record<string, string> = {
    'Practice 1': 'FP1',   'Practice 2': 'FP2',   'Practice 3': 'FP3',
    'Free Practice 1': 'FP1', 'Free Practice 2': 'FP2', 'Free Practice 3': 'FP3',
    'Sprint Qualifying': 'SQ', 'Sprint Shootout': 'SQ', 'Sprint': 'Sprint',
    'Qualifying': 'Quali', 'Feature Race': 'Race', 'Race': 'Race', 'Warm Up': 'WU',
  };

  // ── Filter UI ─────────────────────────────────────────────────────────────
  function renderFilter() {
    const showAll = activeFilters.size === 0;
    const seriesInData = SERIES_ORDER.filter(id => allSeriesIds.includes(id));
    const fourWheelIds = seriesInData.filter(id => SERIES_META[id]?.category === '4-wheel');
    const twoWheelIds  = seriesInData.filter(id => SERIES_META[id]?.category === '2-wheel');

    // ── Category buttons ──
    const catContainer = document.getElementById('cal-cat-filter')!;
    const catDefs = [
      { key: 'all',     label: 'All',        ids: seriesInData },
      { key: '4-wheel', label: '🚗 4-Wheel', ids: fourWheelIds },
      { key: '2-wheel', label: '🏍 2-Wheel', ids: twoWheelIds  },
    ];

    // Keep the label span, re-render only buttons
    const existingBtns = catContainer.querySelectorAll('.cal-cat-btn');
    if (existingBtns.length === 0) {
      catContainer.insertAdjacentHTML('beforeend', catDefs.map(({ key, label }) =>
        `<button class="cal-cat-btn text-xs px-3 py-1 rounded-full border font-semibold transition-all duration-150 select-none" data-cat="${key}">${label}</button>`
      ).join(''));

      catContainer.querySelectorAll<HTMLButtonElement>('.cal-cat-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const cat = btn.dataset.cat!;
          if (cat === 'all') {
            activeFilters.clear();
          } else {
            const ids = cat === '4-wheel' ? fourWheelIds : twoWheelIds;
            const allSelected = ids.every(id => activeFilters.has(id));
            const isExclusive = allSelected && [...activeFilters].every(id => ids.includes(id));
            if (isExclusive) {
              activeFilters.clear();
            } else {
              activeFilters.clear();
              ids.forEach(id => activeFilters.add(id));
            }
          }
          selectedDate = null;
          saveFiltersToStorage();
          renderFilter();
          renderMonth();
          renderDayDetail();
        });
      });
    }

    // Style category buttons
    catContainer.querySelectorAll<HTMLButtonElement>('.cal-cat-btn').forEach(btn => {
      const cat = btn.dataset.cat!;
      let state: 'active' | 'partial' | 'inactive';
      if (cat === 'all') {
        state = showAll ? 'active' : 'inactive';
      } else {
        const ids = cat === '4-wheel' ? fourWheelIds : twoWheelIds;
        if (showAll || ids.every(id => activeFilters.has(id))) {
          const isExclusive = !showAll && [...activeFilters].every(id => ids.includes(id));
          state = isExclusive ? 'active' : 'partial';
        } else {
          state = ids.some(id => activeFilters.has(id)) ? 'partial' : 'inactive';
        }
      }
      if (state === 'active') {
        btn.style.cssText = 'background-color:#27272a;border-color:#71717a;color:#f4f4f5';
      } else if (state === 'partial') {
        btn.style.cssText = 'background-color:#1c1c1e;border-color:#52525b;color:#a1a1aa';
      } else {
        btn.style.cssText = 'background-color:transparent;border-color:#3f3f46;color:#52525b';
      }
    });

    // ── Individual series chips ──
    const container = document.getElementById('cal-filter')!;
    container.innerHTML = seriesInData.map((id, i) => {
      const m = SERIES_META[id] ?? { shortLabel: id, color: '#71717a', category: '4-wheel' };
      const on = showAll || activeFilters.has(id);
      const style = on
        ? `background-color:${m.color}20;border-color:${m.color}60;color:${m.color}`
        : 'background-color:transparent;border-color:#3f3f46;color:#52525b';
      // Add visual divider before first 2-wheel series
      const divider = (i > 0 && m.category === '2-wheel' && SERIES_META[seriesInData[i - 1]]?.category === '4-wheel')
        ? '<span class="h-4 w-px bg-zinc-700/60 self-center mx-0.5" aria-hidden="true"></span>'
        : '';
      return `${divider}<button class="cal-filter-btn text-xs font-bold px-2.5 py-1 rounded-full border transition-all duration-150 select-none" data-series="${id}" style="${style}">
        <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background-color:${m.color};margin-right:3px;vertical-align:middle"></span>${m.shortLabel}
      </button>`;
    }).join('');

    container.querySelectorAll<HTMLButtonElement>('.cal-filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.series!;
        if (activeFilters.has(id)) {
          activeFilters.delete(id);
        } else {
          // If currently showing all, switch to "all except this one" when deselecting
          if (showAll) {
            allSeriesIds.forEach(s => { if (s !== id) activeFilters.add(s); });
          } else {
            activeFilters.add(id);
          }
        }
        selectedDate = null;
        saveFiltersToStorage();
        renderFilter();
        renderMonth();
        renderDayDetail();
      });
    });
  }

  // ── Month grid ────────────────────────────────────────────────────────────
  function renderMonth() {
    const grid  = document.getElementById('cal-grid')!;
    const label = document.getElementById('cal-month-label')!;

    label.textContent = new Date(displayYear, displayMonth, 1)
      .toLocaleDateString('en', { month: 'long', year: 'numeric' });

    const firstDay  = new Date(displayYear, displayMonth, 1);
    const totalDays = new Date(displayYear, displayMonth + 1, 0).getDate();
    const startOffset = monDow(firstDay); // leading blank cells
    const todayStr  = toDateStr(todayDate);
    const cells: string[] = [];

    // Leading empty cells
    for (let i = 0; i < startOffset; i++) {
      cells.push('<div class="bg-zinc-950 min-h-[76px] sm:min-h-[96px]"></div>');
    }

    for (let day = 1; day <= totalDays; day++) {
      const dateStr  = `${displayYear}-${String(displayMonth + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const isToday  = dateStr === todayStr;
      const isPast   = dateStr < todayStr;
      const isSel    = dateStr === selectedDate;
      const evs      = eventsOnDate(dateStr);

      // Deduplicate: one badge per series per day
      const seenSeries = new Set<string>();
      const uniqueEvs = evs.filter(e => {
        if (seenSeries.has(e.seriesId)) return false;
        seenSeries.add(e.seriesId);
        return true;
      });

      const MAX_BADGES = 3;
      const visible  = uniqueEvs.slice(0, MAX_BADGES);
      const overflow = uniqueEvs.length - MAX_BADGES;

      const badgesHtml = visible.map(e => {
        const m = SERIES_META[e.seriesId] ?? { shortLabel: e.seriesId, color: '#71717a' };
        const isRaceDay = e.dateEnd === dateStr;
        const bg   = isRaceDay ? m.color + 'ee' : m.color + '28';
        const text = isRaceDay ? '#ffffff' : m.color;
        return `<span
          class="shrink-0 text-[9px] font-bold leading-none rounded px-1 py-0.5 whitespace-nowrap block"
          style="background-color:${bg};color:${text}"
          title="${e.eventName}"
        >${m.shortLabel}</span>`;
      }).join('');

      const overflowHtml = overflow > 0
        ? `<span class="text-[9px] text-zinc-600 font-medium leading-none">+${overflow}</span>`
        : '';

      const dayNumClass = isToday
        ? 'w-5 h-5 sm:w-6 sm:h-6 rounded-full flex items-center justify-center bg-emerald-500 text-zinc-950 font-black text-[10px] sm:text-xs leading-none'
        : isPast
          ? 'text-xs sm:text-sm font-medium text-zinc-700 leading-none'
          : 'text-xs sm:text-sm font-medium text-zinc-300 leading-none';

      const cellBase = 'cal-day relative bg-zinc-950 transition-colors cursor-pointer min-h-[76px] sm:min-h-[96px] p-1.5 sm:p-2';
      const cellState = isSel
        ? 'ring-1 ring-inset ring-zinc-500 bg-zinc-900/80 hover:bg-zinc-900'
        : 'hover:bg-zinc-900/60';

      cells.push(`<div class="${cellBase} ${cellState}" data-date="${dateStr}" role="button" tabindex="0" aria-label="${dateStr}${evs.length > 0 ? `, ${evs.length} event${evs.length > 1 ? 's' : ''}` : ''}">
        <div class="flex items-start justify-between mb-1">
          <span class="${dayNumClass}">${day}</span>
        </div>
        <div class="flex flex-wrap gap-0.5 sm:gap-1">
          ${badgesHtml}${overflowHtml}
        </div>
      </div>`);
    }

    // Trailing empty cells to fill last row
    const used = startOffset + totalDays;
    const trail = (7 - (used % 7)) % 7;
    for (let i = 0; i < trail; i++) {
      cells.push('<div class="bg-zinc-950 min-h-[76px] sm:min-h-[96px]"></div>');
    }

    grid.innerHTML = cells.join('');

    grid.querySelectorAll<HTMLElement>('.cal-day').forEach(cell => {
      cell.addEventListener('click', () => {
        const d = cell.dataset.date!;
        selectedDate = selectedDate === d ? null : d;
        renderMonth();
        renderDayDetail();
      });
      cell.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); cell.click(); }
      });
    });
  }

  // ── Day detail panel ──────────────────────────────────────────────────────
  function renderDayDetail() {
    const panel = document.getElementById('cal-day-detail')!;

    if (!selectedDate) { panel.innerHTML = ''; return; }

    const dayEvs = eventsOnDate(selectedDate);
    if (dayEvs.length === 0) { panel.innerHTML = ''; return; }

    const dateLabel = new Date(selectedDate + 'T12:00:00').toLocaleDateString('en', {
      weekday: 'long', month: 'long', day: 'numeric',
    });

    function sessionsOnDay(ev: any, dateStr: string): any[] {
      return (ev.sessions ?? []).filter((s: any) => {
        if (s.startTimeUTC.startsWith('1900')) return false;
        // Session falls on this date in UTC — good enough for display
        return s.startTimeUTC.slice(0, 10) === dateStr ||
               // Edge case: session might be late and cross midnight, check ±1 day
               new Date(s.startTimeUTC).toLocaleDateString('en-CA') === dateStr;
      });
    }

    const cardsHtml = dayEvs.map(ev => {
      const m = SERIES_META[ev.seriesId] ?? { shortLabel: ev.seriesId, color: '#71717a', label: ev.seriesId };
      const sessions = sessionsOnDay(ev, selectedDate!);
      const f = flag(ev.circuit?.countryCode ?? '');
      const isRaceDay = ev.dateEnd === selectedDate;
      const isPast = new Date(ev.dateEnd + 'T23:59:59Z') < new Date();
      const isFirstDay = ev.dateStart === selectedDate;

      const sessHtml = sessions.map((s: any) => {
        const lbl = SESSION_ABBR[s.type] ?? s.type;
        const isRace = s.type === 'Race' || s.type === 'Feature Race';
        const t = fmtTime(s.startTimeUTC);
        return `<div class="flex items-center gap-1.5 text-xs">
          <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background-color:${isRace ? m.color : '#3f3f46'}"></span>
          <span class="font-semibold ${isRace ? 'text-zinc-100' : 'text-zinc-400'}">${lbl}</span>
          <span class="tabular-nums text-zinc-600">${t}</span>
        </div>`;
      }).join('');

      // Weekend span label
      const spanLabel = ev.dateStart === ev.dateEnd
        ? ''
        : isFirstDay
          ? `<span class="text-[10px] text-zinc-600">Weekend starts</span>`
          : isRaceDay
            ? `<span class="text-[10px] font-bold uppercase tracking-wider" style="color:${m.color}">Race day</span>`
            : `<span class="text-[10px] text-zinc-600">Race weekend</span>`;

      return `<article
        class="cal-detail-card flex gap-3 p-3 rounded-xl border cursor-pointer transition-colors ${isPast ? 'border-zinc-800/40 bg-zinc-900/20 opacity-50' : 'border-zinc-800 bg-zinc-900 hover:border-zinc-700'}"
        data-event='${JSON.stringify(ev).replace(/'/g, '&#39;')}'
        role="button" tabindex="0"
      >
        <div class="w-0.5 self-stretch rounded-full shrink-0" style="background-color:${m.color}"></div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1 flex-wrap">
            <span class="text-xs font-bold px-2 py-0.5 rounded text-white uppercase tracking-wide" style="background-color:${m.color}">${m.shortLabel}</span>
            <span class="text-[11px] text-zinc-500 font-mono">Rd ${ev.round}</span>
            ${spanLabel}
          </div>
          <h3 class="font-bold text-sm ${isPast ? 'text-zinc-500' : 'text-zinc-100'} mb-1">${ev.eventName}</h3>
          <div class="flex items-center gap-1.5 text-xs text-zinc-500 ${sessions.length > 0 ? 'mb-2' : ''}">
            ${f ? `<span class="text-sm">${f}</span>` : ''}<span>${ev.circuit?.name ?? ''}</span>
          </div>
          ${sessions.length > 0 ? `<div class="flex flex-wrap gap-x-3 gap-y-1">${sessHtml}</div>` : ''}
        </div>
      </article>`;
    }).join('');

    panel.innerHTML = `
      <div class="mt-3 border border-zinc-800 rounded-xl overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b border-zinc-800 bg-zinc-900/40">
          <span class="font-semibold text-sm text-zinc-200">${dateLabel}</span>
          <button id="cal-detail-close" class="text-zinc-600 hover:text-zinc-300 transition-colors p-1" aria-label="Close">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <div class="p-3 grid gap-2 sm:grid-cols-2">
          ${cardsHtml}
        </div>
      </div>
    `;

    document.getElementById('cal-detail-close')!.addEventListener('click', () => {
      selectedDate = null;
      renderMonth();
      renderDayDetail();
    });

    panel.querySelectorAll<HTMLElement>('.cal-detail-card').forEach(card => {
      card.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('rt-open-event', {
          detail: JSON.parse(card.dataset.event!),
        }));
      });
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); }
      });
    });

    // Scroll detail panel into view smoothly
    panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // ── Month navigation ──────────────────────────────────────────────────────
  document.getElementById('cal-prev')!.addEventListener('click', () => {
    if (--displayMonth < 0) { displayMonth = 11; displayYear--; }
    selectedDate = null;
    renderMonth();
    renderDayDetail();
  });

  document.getElementById('cal-next')!.addEventListener('click', () => {
    if (++displayMonth > 11) { displayMonth = 0; displayYear++; }
    selectedDate = null;
    renderMonth();
    renderDayDetail();
  });

  document.getElementById('cal-today-btn')!.addEventListener('click', () => {
    displayYear  = todayDate.getFullYear();
    displayMonth = todayDate.getMonth();
    selectedDate = null;
    renderMonth();
    renderDayDetail();
  });

  // ── Bootstrap ─────────────────────────────────────────────────────────────
  function init() {
    loadFiltersFromStorage();
    renderFilter();
    renderMonth();
    renderDayDetail();
  }

  // Sync when filter changes on another page (e.g. dashboard)
  window.addEventListener('rt-filters-changed', (e: any) => {
    const ids: string[] = e.detail.active ?? [];
    activeFilters.clear();
    ids.forEach((id: string) => { if (allSeriesIds.includes(id)) activeFilters.add(id); });
    selectedDate = null;
    renderFilter();
    renderMonth();
    renderDayDetail();
  });

  init();
  document.addEventListener('astro:after-swap', init);
</script>
