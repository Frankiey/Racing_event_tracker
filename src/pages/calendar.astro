---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import SeriesFilter from '../components/SeriesFilter.astro';
import { SERIES_LIST } from '../lib/series';

import calendarData from '../../data/gold/calendar.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const events = calendarData as any[];

// Group by month
const grouped = new Map<string, typeof events>();
for (const event of events) {
  const d = new Date(event.dateStart);
  const label = d.toLocaleDateString('en', { month: 'long', year: 'numeric' });
  if (!grouped.has(label)) grouped.set(label, []);
  grouped.get(label)!.push(event);
}

// Stats
const seriesCounts = new Map<string, number>();
for (const e of events) {
  seriesCounts.set(e.seriesId, (seriesCounts.get(e.seriesId) ?? 0) + 1);
}
---

<Layout title="RaceTrack — Full Calendar" currentPath={`${base}/calendar`}>
  <main class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-bold mb-1">2026 Calendar</h1>
      <p class="text-zinc-400 text-sm">
        {events.length} events across {seriesCounts.size} series
      </p>
    </div>

    <SeriesFilter />

    {[...grouped.entries()].map(([month, monthEvents]) => (
      <section class="mb-8">
        <h2 class="text-sm font-semibold text-zinc-500 uppercase tracking-wide mb-3 sticky top-12 bg-zinc-950/90 backdrop-blur-sm py-2 -mx-4 px-4 z-10">
          {month}
          <span class="text-zinc-600 font-normal ml-2">({monthEvents.length})</span>
        </h2>
        <div class="grid gap-3">
          {monthEvents.map(event => (
            <div data-series={event.seriesId}>
              <EventCard event={event} />
            </div>
          ))}
        </div>
      </section>
    ))}
  </main>
</Layout>
