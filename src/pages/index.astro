---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import SeriesFilter from '../components/SeriesFilter.astro';
import { getRaceSession, isPlaceholderTime, countryFlag } from '../lib/time';
import { SERIES_LIST, getSeriesMeta } from '../lib/series';
import type { RaceEvent } from '../lib/types';

import upcomingData from '../../data/gold/upcoming.json';
import calendarData from '../../data/gold/calendar.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const now = new Date();
const SEASON_YEAR = now.getFullYear();
const upcoming = (upcomingData as any).events as RaceEvent[];
const allEvents = (calendarData as any).events as RaceEvent[];

// Find the next race session across all series
const nextRace = upcoming
  .map(e => ({ event: e, session: getRaceSession(e.sessions) }))
  .filter(x => x.session && !isPlaceholderTime(x.session.startTimeUTC) && new Date(x.session.startTimeUTC) > now)
  .sort((a, b) => new Date(a.session!.startTimeUTC).getTime() - new Date(b.session!.startTimeUTC).getTime())[0];

const fallbackHero = nextRace
  ?? upcoming
    .map(e => ({ event: e, session: getRaceSession(e.sessions) }))
    .find(x => x.session && !isPlaceholderTime(x.session.startTimeUTC));

// Season stats per series: total rounds and rounds completed
const seasonStats = new Map<string, { total: number; done: number }>();
for (const e of allEvents) {
  const s = seasonStats.get(e.seriesId) ?? { total: 0, done: 0 };
  s.total++;
  if (new Date(e.dateEnd + 'T23:59:59Z') < now) s.done++;
  seasonStats.set(e.seriesId, s);
}

// Aggregate season stats
const totalEvents = allEvents.length;
const totalDone = allEvents.filter(e => new Date(e.dateEnd + 'T23:59:59Z') < now).length;
const totalUpcoming = totalEvents - totalDone;
const totalSeries = seasonStats.size;
const allCountries = new Set(allEvents.map(e => e.circuit.countryCode).filter(Boolean));

// Busiest month
const monthCounts = new Map<string, number>();
for (const e of allEvents) {
  const m = new Date(e.dateStart + 'T12:00:00Z').toLocaleDateString('en', { month: 'long' });
  monthCounts.set(m, (monthCounts.get(m) ?? 0) + 1);
}
const busiestMonth = [...monthCounts.entries()].sort((a, b) => b[1] - a[1])[0];

// Busiest weekend (Fri-Sun window)
const weekendCounts = new Map<string, { count: number; series: Set<string> }>();
for (const e of allEvents) {
  const d = new Date(e.dateStart + 'T12:00:00Z');
  // Snap to the Friday of the week
  const dow = d.getUTCDay();
  const fri = new Date(d);
  fri.setUTCDate(fri.getUTCDate() - ((dow + 2) % 7)); // 0=Sun -> back 2, 5=Fri -> 0
  const key = fri.toISOString().slice(0, 10);
  const entry = weekendCounts.get(key) ?? { count: 0, series: new Set() };
  entry.count++;
  entry.series.add(e.seriesId);
  weekendCounts.set(key, entry);
}
const busiestWeekend = [...weekendCounts.entries()].sort((a, b) => b[1].count - a[1].count)[0];
const busiestWeekendLabel = busiestWeekend
  ? (() => { const d = new Date(busiestWeekend[0] + 'T12:00:00Z'); return d.toLocaleDateString('en', { month: 'short', day: 'numeric' }); })()
  : '';

// Clash detector: find weekends with 3+ series
const clashWeekends: { dateLabel: string; dateStart: string; series: string[]; events: RaceEvent[] }[] = [];
for (const [key, val] of weekendCounts.entries()) {
  if (val.series.size >= 3) {
    const d = new Date(key + 'T12:00:00Z');
    const sun = new Date(d); sun.setUTCDate(sun.getUTCDate() + 2);
    const label = `${d.toLocaleDateString('en', { month: 'short', day: 'numeric' })}–${sun.getUTCDate()}`;
    const evts = allEvents.filter(e => {
      const eStart = new Date(e.dateStart + 'T12:00:00Z');
      return eStart >= d && eStart <= sun;
    });
    clashWeekends.push({ dateLabel: label, dateStart: key, series: [...val.series], events: evts });
  }
}
clashWeekends.sort((a, b) => a.dateStart.localeCompare(b.dateStart));
const upcomingClashes = clashWeekends.filter(c => c.dateStart >= now.toISOString().slice(0, 10));

// Sort chronologically (upcoming.json is grouped by series, not sorted by date)
const sortedUpcoming = [...upcoming].sort((a: any, b: any) => a.dateStart.localeCompare(b.dateStart));

// Build full event list with a per-series cap (no total cap — lazy load handles paging)
const MAX_PER_SERIES = 6;
const seriesCounts = new Map<string, number>();
const dashboardEvents: typeof upcoming = [];
for (const event of sortedUpcoming) {
  const count = seriesCounts.get(event.seriesId) ?? 0;
  if (count >= MAX_PER_SERIES) continue;
  seriesCounts.set(event.seriesId, count + 1);
  dashboardEvents.push(event);
}
dashboardEvents.sort((a: any, b: any) => a.dateStart.localeCompare(b.dateStart));

// Group by week label
function getWeekLabel(event: any): string {
  // Use the race session start time for past-detection if available;
  // fall back to dateEnd for events with placeholder/missing race times.
  const raceSession = getRaceSession(event.sessions);
  const isPast = (raceSession && !isPlaceholderTime(raceSession.startTimeUTC))
    ? new Date(raceSession.startTimeUTC) < now
    : new Date(event.dateEnd + 'T23:59:59Z') < now;
  if (isPast) return '__recent__';

  const eventDate = new Date(event.dateStart + 'T12:00:00Z');
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  const diffDays = Math.floor((eventDate.getTime() - today.getTime()) / 86400000);
  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return 'Tomorrow';
  if (diffDays <= 7) return 'This week';
  if (diffDays <= 14) return 'Next week';
  return eventDate.toLocaleDateString('en', { month: 'long', year: 'numeric' });
}

// Track the first event's dateStart per section so client-side JS can recompute labels
const grouped = new Map<string, typeof dashboardEvents>();
const groupFirstDate = new Map<string, string>();
for (const event of dashboardEvents) {
  const label = getWeekLabel(event);
  if (!grouped.has(label)) {
    grouped.set(label, []);
    groupFirstDate.set(label, event.dateStart);
  }
  grouped.get(label)!.push(event);
}

const recentEvents = grouped.get('__recent__') ?? [];
const visibleGroups = [...grouped.entries()].filter(([k]) => k !== '__recent__');

// First 2 groups render visible; the rest are in the DOM but hidden — revealed by lazy loader
const INITIAL_GROUPS = 2;

const heroEventsJson = JSON.stringify(upcoming).replace(/</g, '\\u003c');
const nextCircuitFlag = fallbackHero ? countryFlag(fallbackHero.event.circuit.countryCode) : '';
const nextRaceMeta = fallbackHero ? getSeriesMeta(fallbackHero.event.seriesId) : null;
---

<Layout title="RaceTrack — Motorsport Event Tracker" currentPath={`${base}/`}>
  <main class="max-w-5xl mx-auto px-4 py-8">

    <!-- ── Hero countdown ── -->
    {fallbackHero && (
      <>
      <div class="relative mb-8 rounded-2xl overflow-hidden border border-zinc-700/40" data-hero-card>
        <div class="absolute inset-0 bg-gradient-to-br from-zinc-900 via-zinc-900 to-zinc-950" />
        <div
          data-hero-glow
          class="absolute inset-0 opacity-[0.07]"
          style={`background: radial-gradient(ellipse 80% 60% at 80% 50%, ${nextRaceMeta?.color ?? '#e10600'}, transparent)`}
        />
        <div data-hero-accent class="absolute left-0 inset-y-0 w-1 rounded-l-2xl" style={`background: ${nextRaceMeta?.color ?? '#e10600'};`} />

        <div class="relative px-6 py-6 sm:px-8 sm:py-7">
          <div class="flex flex-col sm:flex-row sm:items-center gap-5 sm:gap-8">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2.5 mb-3 flex-wrap">
                <span
                  data-hero-series-badge
                  class="inline-block rounded font-bold uppercase tracking-wide text-white text-xs px-2 py-0.5"
                  style={`background-color: ${nextRaceMeta?.color ?? '#e10600'};`}
                >
                  {nextRaceMeta?.shortLabel ?? fallbackHero.event.seriesId}
                </span>
                <span data-hero-round class="text-xs text-zinc-500 font-mono">Round {fallbackHero.event.round}</span>
                <span
                  data-hero-status
                  class="text-[10px] px-2 py-0.5 rounded-full font-bold uppercase tracking-widest"
                  style={`background-color: ${nextRaceMeta?.color ?? '#e10600'}20; color: ${nextRaceMeta?.color ?? '#e10600'}`}
                >
                  Next Race
                </span>
              </div>
              <h2 data-hero-title class="text-2xl sm:text-3xl font-black text-zinc-100 tracking-tight leading-none mb-2">
                {fallbackHero.event.eventName}
              </h2>
              <p class="flex items-center gap-2 text-sm text-zinc-400">
                <span data-hero-flag class:list={['text-xl leading-none', !nextCircuitFlag && 'hidden']}>{nextCircuitFlag}</span>
                <span data-hero-circuit class="font-medium">{fallbackHero.event.circuit.name}</span>
                <span data-hero-country-wrap class:list={[!fallbackHero.event.circuit.country && 'hidden']}>
                  <span class="text-zinc-700">·</span>
                  <span data-hero-country class="text-zinc-500">{fallbackHero.event.circuit.country}</span>
                </span>
              </p>
            </div>

            <div class="sm:text-right shrink-0">
              <div class="text-center" data-hero-countdown data-countdown={fallbackHero.session!.startTimeUTC}>
                <p data-hero-countdown-label class="text-xs text-zinc-500 uppercase tracking-wide mb-1">Race starts in</p>
                <div class="flex items-center justify-center gap-3 text-2xl font-mono font-bold text-zinc-100">
                  <div class="flex flex-col items-center">
                    <span data-unit="days" class="tabular-nums">--</span>
                    <span data-hero-days-label class="text-[10px] text-zinc-500 font-sans font-normal">days</span>
                  </div>
                  <span class="text-zinc-600">:</span>
                  <div class="flex flex-col items-center">
                    <span data-unit="hours" class="tabular-nums">--</span>
                    <span class="text-[10px] text-zinc-500 font-sans font-normal">hrs</span>
                  </div>
                  <span class="text-zinc-600">:</span>
                  <div class="flex flex-col items-center">
                    <span data-unit="minutes" class="tabular-nums">--</span>
                    <span class="text-[10px] text-zinc-500 font-sans font-normal">min</span>
                  </div>
                  <span class="text-zinc-600">:</span>
                  <div class="flex flex-col items-center">
                    <span data-unit="seconds" class="tabular-nums">--</span>
                    <span class="text-[10px] text-zinc-500 font-sans font-normal">sec</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <script id="rt-hero-events" type="application/json" set:html={heroEventsJson}></script>
      <script>
        import { countryFlag } from '../lib/client-utils';
        import { SERIES_META } from '../lib/series-client';

        type HeroSession = { type: string; startTimeUTC: string; endTimeUTC?: string };
        type HeroEvent = {
          id: string;
          seriesId: string;
          eventName: string;
          round: number;
          circuit: { name: string; country: string; countryCode: string };
          sessions: HeroSession[];
        };

        type HeroCandidate = {
          event: HeroEvent;
          session: HeroSession;
          mode: 'live' | 'next';
        };

        const HERO_RACE_TYPES = new Set(['Race', 'Feature Race', 'Race 1', 'Race 2', 'Sprint Race', 'Superpole Race', 'Sprint']);
        const HERO_SESSION_DURATION_MIN: Record<string, number> = {
          'Practice': 60,
          'Practice 1': 60,
          'Practice 2': 60,
          'Practice 3': 60,
          'Free Practice 1': 60,
          'Free Practice 2': 60,
          'Free Practice 3': 60,
          'FP1': 45,
          'FP2': 45,
          'FP3': 45,
          'Q1': 20,
          'Q2': 20,
          'Qualifying': 90,
          'Sprint Qualifying': 60,
          'Sprint Shootout': 60,
          'Sprint': 45,
          'Sprint Race': 45,
          'Race': 120,
          'Race 1': 120,
          'Race 2': 120,
          'Feature Race': 120,
          'Superpole Race': 45,
          'NASCAR Race': 180,
          'MotoGP Race': 60,
          'Warm Up': 30,
          default: 120,
        };

        let heroInterval: number | undefined;

        function isPlaceholderTime(utc: string): boolean {
          return !utc || utc.startsWith('1900-');
        }

        function getRaceSession(sessions: HeroSession[]): HeroSession | null {
          return sessions.find(session => HERO_RACE_TYPES.has(session.type)) ?? sessions.at(-1) ?? null;
        }

        function getSessionEnd(session: HeroSession): number {
          if (session.endTimeUTC) {
            const explicitEnd = new Date(session.endTimeUTC).getTime();
            if (!Number.isNaN(explicitEnd)) return explicitEnd;
          }

          const durationMin = HERO_SESSION_DURATION_MIN[session.type] ?? HERO_SESSION_DURATION_MIN.default;
          return new Date(session.startTimeUTC).getTime() + durationMin * 60_000;
        }

        function getHeroCandidate(events: HeroEvent[], now: number): HeroCandidate | null {
          const raceEntries = events
            .map(event => ({ event, session: getRaceSession(event.sessions ?? []) }))
            .filter((entry): entry is { event: HeroEvent; session: HeroSession } => !!entry.session && !isPlaceholderTime(entry.session.startTimeUTC))
            .sort((a, b) => new Date(a.session.startTimeUTC).getTime() - new Date(b.session.startTimeUTC).getTime());

          const live = raceEntries.find(({ session }) => {
            const start = new Date(session.startTimeUTC).getTime();
            return now >= start && now < getSessionEnd(session);
          });
          if (live) return { ...live, mode: 'live' };

          const next = raceEntries.find(({ session }) => new Date(session.startTimeUTC).getTime() > now);
          return next ? { ...next, mode: 'next' } : null;
        }

        function setUnit(root: HTMLElement, unit: string, value: string) {
          const node = root.querySelector<HTMLElement>(`[data-unit="${unit}"]`);
          if (node) node.textContent = value;
        }

        function updateCountdown(root: HTMLElement, candidate: HeroCandidate, now: number) {
          const start = new Date(candidate.session.startTimeUTC).getTime();
          const end = getSessionEnd(candidate.session);
          const label = root.querySelector<HTMLElement>('[data-hero-countdown-label]');
          const daysLabel = root.querySelector<HTMLElement>('[data-hero-days-label]');

          if (candidate.mode === 'live' && now < end) {
            const elapsed = now - start;
            const elapsedMinutes = Math.floor(elapsed / 60_000);
            const elapsedHours = Math.floor(elapsedMinutes / 60);

            if (label) {
              label.innerHTML = '<span class="live-pulse inline-flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400 inline-block"></span><span class="text-emerald-400">In Progress</span></span>';
            }
            if (daysLabel) daysLabel.textContent = 'elapsed';

            setUnit(root, 'days', '0');
            setUnit(root, 'hours', String(elapsedHours).padStart(2, '0'));
            setUnit(root, 'minutes', String(elapsedMinutes % 60).padStart(2, '0'));
            setUnit(root, 'seconds', String(Math.floor((elapsed % 60_000) / 1000)).padStart(2, '0'));
            return;
          }

          const diff = Math.max(0, start - now);
          const days = Math.floor(diff / 86_400_000);
          const hours = Math.floor((diff % 86_400_000) / 3_600_000);
          const minutes = Math.floor((diff % 3_600_000) / 60_000);
          const seconds = Math.floor((diff % 60_000) / 1000);

          if (label) label.textContent = 'Race starts in';
          if (daysLabel) daysLabel.textContent = 'days';

          setUnit(root, 'days', String(days));
          setUnit(root, 'hours', String(hours).padStart(2, '0'));
          setUnit(root, 'minutes', String(minutes).padStart(2, '0'));
          setUnit(root, 'seconds', String(seconds).padStart(2, '0'));
        }

        function renderHero(card: HTMLElement, candidate: HeroCandidate) {
          const meta = SERIES_META[candidate.event.seriesId] ?? {
            shortLabel: candidate.event.seriesId.toUpperCase(),
            color: '#71717a',
          };
          const color = meta.color;
          const flag = countryFlag(candidate.event.circuit.countryCode);

          const glow = card.querySelector<HTMLElement>('[data-hero-glow]');
          const accent = card.querySelector<HTMLElement>('[data-hero-accent]');
          const badge = card.querySelector<HTMLElement>('[data-hero-series-badge]');
          const round = card.querySelector<HTMLElement>('[data-hero-round]');
          const status = card.querySelector<HTMLElement>('[data-hero-status]');
          const title = card.querySelector<HTMLElement>('[data-hero-title]');
          const flagEl = card.querySelector<HTMLElement>('[data-hero-flag]');
          const circuit = card.querySelector<HTMLElement>('[data-hero-circuit]');
          const country = card.querySelector<HTMLElement>('[data-hero-country]');
          const countryWrap = card.querySelector<HTMLElement>('[data-hero-country-wrap]');

          if (glow) glow.style.background = `radial-gradient(ellipse 80% 60% at 80% 50%, ${color}, transparent)`;
          if (accent) accent.style.background = color;
          if (badge) {
            badge.textContent = meta.shortLabel;
            badge.style.backgroundColor = color;
          }
          if (round) round.textContent = `Round ${candidate.event.round}`;
          if (status) {
            status.textContent = candidate.mode === 'live' ? 'Live Now' : 'Next Race';
            status.style.backgroundColor = `${color}20`;
            status.style.color = color;
          }
          if (title) title.textContent = candidate.event.eventName;
          if (flagEl) {
            flagEl.textContent = flag;
            flagEl.classList.toggle('hidden', !flag);
          }
          if (circuit) circuit.textContent = candidate.event.circuit.name;
          if (country) country.textContent = candidate.event.circuit.country;
          if (countryWrap) countryWrap.classList.toggle('hidden', !candidate.event.circuit.country);
        }

        function initHeroCard() {
          const card = document.querySelector<HTMLElement>('[data-hero-card]');
          if (!(card instanceof HTMLElement)) return;

          const countdown = card.querySelector<HTMLElement>('[data-hero-countdown]');
          const dataEl = document.getElementById('rt-hero-events');
          if (!(countdown instanceof HTMLElement) || !dataEl) return;

          const cardEl: HTMLElement = card;
          const countdownEl: HTMLElement = countdown;

          const events = JSON.parse(dataEl.textContent ?? '[]') as HeroEvent[];
          let currentKey = '';

          function tick() {
            const now = Date.now();
            const candidate = getHeroCandidate(events, now);
            if (!candidate) {
              cardEl.hidden = true;
              return;
            }

            cardEl.hidden = false;
            const candidateKey = `${candidate.event.id}:${candidate.session.startTimeUTC}:${candidate.mode}`;
            if (candidateKey !== currentKey) {
              renderHero(cardEl, candidate);
              currentKey = candidateKey;
            }
            updateCountdown(countdownEl, candidate, now);
          }

          if (heroInterval) window.clearInterval(heroInterval);
          tick();
          heroInterval = window.setInterval(tick, 1000);
        }

        function cleanupHeroCard() {
          if (heroInterval) {
            window.clearInterval(heroInterval);
            heroInterval = undefined;
          }
        }

        initHeroCard();
        document.addEventListener('astro:before-swap', cleanupHeroCard);
        document.addEventListener('astro:after-swap', initHeroCard);
      </script>
      </>
    )}

    <!-- ── Season overview stats ── -->
    <div class="mb-6 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2">
      <div class="bg-zinc-900/60 border border-zinc-800 rounded-xl p-3 text-center">
        <p class="text-2xl font-black text-zinc-100 tabular-nums">{totalEvents}</p>
        <p class="text-[10px] text-zinc-500 uppercase tracking-widest mt-0.5">Events</p>
      </div>
      <div class="bg-zinc-900/60 border border-zinc-800 rounded-xl p-3 text-center">
        <p class="text-2xl font-black text-zinc-100 tabular-nums">{totalSeries}</p>
        <p class="text-[10px] text-zinc-500 uppercase tracking-widest mt-0.5">Series</p>
      </div>
      <div class="bg-zinc-900/60 border border-zinc-800 rounded-xl p-3 text-center">
        <p class="text-2xl font-black text-emerald-400 tabular-nums">{totalDone}</p>
        <p class="text-[10px] text-zinc-500 uppercase tracking-widest mt-0.5">Done</p>
      </div>
      <div class="bg-zinc-900/60 border border-zinc-800 rounded-xl p-3 text-center">
        <p class="text-2xl font-black text-zinc-100 tabular-nums">{totalUpcoming}</p>
        <p class="text-[10px] text-zinc-500 uppercase tracking-widest mt-0.5">Upcoming</p>
      </div>
      <div class="bg-zinc-900/60 border border-zinc-800 rounded-xl p-3 text-center">
        <p class="text-2xl font-black text-zinc-100 tabular-nums">{allCountries.size}</p>
        <p class="text-[10px] text-zinc-500 uppercase tracking-widest mt-0.5">Countries</p>
      </div>
      {busiestMonth && (
        <div class="bg-zinc-900/60 border border-zinc-800 rounded-xl p-3 text-center">
          <p class="text-lg font-black text-zinc-100">{busiestMonth[0]}</p>
          <p class="text-[10px] text-zinc-500 uppercase tracking-widest mt-0.5">Busiest ({busiestMonth[1]})</p>
        </div>
      )}
    </div>

    <!-- ── Upcoming clashes ── -->
    {upcomingClashes.length > 0 && (
      <div class="mb-6">
        <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3 flex items-center gap-3">
          ⚡ Upcoming Clashes
          <span class="h-px flex-1 bg-zinc-800/60" />
        </h2>
        <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
          {upcomingClashes.slice(0, 6).map(clash => (
            <div class="bg-zinc-900/60 border border-amber-900/30 rounded-xl p-3">
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-semibold text-zinc-200">{clash.dateLabel}</span>
                <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-amber-500/15 text-amber-400 font-bold uppercase tracking-widest">
                  {clash.series.length} series
                </span>
              </div>
              <div class="flex flex-wrap gap-1">
                {clash.series.map(sid => {
                  const m = getSeriesMeta(sid);
                  return (
                    <span
                      class="text-[10px] font-bold px-1.5 py-0.5 rounded text-white"
                      style={`background-color: ${m.color};`}
                    >{m.shortLabel}</span>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- ── Season stats ── -->
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-3 flex-wrap">
        <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">{SEASON_YEAR} Season</h2>
        <span class="h-px flex-1 bg-zinc-800/80" />
        <div id="weekend-share-slot" class="flex items-center gap-2 min-w-0">
          <span id="weekend-share-summary" class="hidden sm:block text-[10px] uppercase tracking-widest text-zinc-600 whitespace-nowrap" />
          <button
            id="weekend-share-btn"
            class="inline-flex items-center gap-1.5 rounded-full border border-zinc-800 bg-zinc-900/70 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-zinc-400 transition hover:border-zinc-700 hover:text-zinc-200 disabled:cursor-not-allowed disabled:opacity-50"
            type="button"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V4.5m0 12 4.5-4.5M12 16.5l-4.5-4.5M4.5 19.5h15" />
            </svg>
            <span id="weekend-share-btn-label">Weekend Card</span>
          </button>
        </div>
        <a href={`${base}/calendar`} class="text-[10px] text-zinc-600 hover:text-zinc-400 transition-colors uppercase tracking-widest">
          Full calendar →
        </a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
        {SERIES_LIST.filter(s => seasonStats.has(s.id)).map(s => {
          const stats = seasonStats.get(s.id)!;
          const pct = stats.total > 0 ? Math.round((stats.done / stats.total) * 100) : 0;
          return (
            <a
              href={`${base}/series/${s.id}`}
              class="group flex flex-col gap-2 bg-zinc-900/60 border border-zinc-800 hover:border-zinc-700 rounded-xl p-3 transition-colors"
            >
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-1.5">
                  <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${s.color}`} />
                  <span class="text-xs font-bold text-zinc-300">{s.shortLabel}</span>
                </div>
                <span class="text-[11px] font-mono text-zinc-500 tabular-nums">{stats.done}/{stats.total}</span>
              </div>
              <div class="h-1 rounded-full bg-zinc-800 overflow-hidden">
                <div class="h-full rounded-full transition-all" style={`width: ${pct}%; background-color: ${s.color};`} />
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <!-- ── Filter ── -->
    <SeriesFilter />

    <!-- Recent — collapsed by default -->
    {recentEvents.length > 0 && (
      <div id="recent-section" class="mb-6">
        <button
          id="recent-toggle"
          class="w-full flex items-center gap-3 text-[10px] font-bold text-zinc-700 uppercase tracking-widest hover:text-zinc-500 transition-colors group"
        >
          <svg id="recent-chevron" class="w-3 h-3 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          <span>Recent ({recentEvents.length})</span>
          <span class="h-px flex-1 bg-zinc-800/40 group-hover:bg-zinc-700/40 transition-colors" />
        </button>
        <div id="recent-events" class="hidden mt-3 grid gap-2.5">
          {recentEvents.map(event => (
            <div data-series={event.seriesId}>
              <EventCard event={event} />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- ── Event groups — first INITIAL_GROUPS visible, rest lazy ── -->
    {visibleGroups.map(([weekLabel, weekEvents], i) => (
      <section
        class="week-group mb-8"
        data-week-section={weekLabel}
        data-week-date={groupFirstDate.get(weekLabel) ?? ''}
        data-lazy-group={i >= INITIAL_GROUPS ? 'true' : undefined}
        style={i >= INITIAL_GROUPS ? 'display:none' : undefined}
      >
        <h2 class="text-[10px] font-bold text-zinc-600 uppercase tracking-widest mb-3 flex items-center gap-3">
          {weekLabel}
          <span class="h-px flex-1 bg-zinc-800/60" />
          <span class="text-zinc-700">{weekEvents.length}</span>
        </h2>
        <div class="grid gap-2.5">
          {weekEvents.map(event => (
            <div
              data-series={event.seriesId}
              class="event-card-wrapper"
              data-race-utc={getRaceSession(event.sessions)?.startTimeUTC ?? ''}
            >
              <EventCard
                event={event}
                highlight={nextRace?.event.id === event.id}
              />
            </div>
          ))}
        </div>
      </section>
    ))}

    {visibleGroups.length === 0 && recentEvents.length === 0 && (
      <div class="text-center py-16 text-zinc-600">
        <p class="text-4xl mb-4">🏁</p>
        <p class="font-semibold mb-1 text-zinc-500">No upcoming events</p>
        <p class="text-sm">Run <code class="bg-zinc-800 text-zinc-300 px-2 py-1 rounded">npm run fetch-data</code> to populate.</p>
      </div>
    )}

    <!-- ── Lazy load sentinel + skeleton + end ── -->
    <div id="lazy-sentinel" class="h-1" />

    <div id="lazy-skeleton" class="hidden space-y-2.5 mb-8" aria-hidden="true">
      {[0, 1, 2].map(i => (
        <div
          class="skeleton-card rounded-xl border border-zinc-800/50"
          style={`height: 112px; animation-delay: ${i * 120}ms`}
        />
      ))}
    </div>

    <div id="lazy-end" class="hidden text-center py-10 text-zinc-700">
      <div class="inline-flex items-center gap-3">
        <span class="h-px w-12 bg-zinc-800" />
        <span class="text-xs uppercase tracking-widest font-semibold">All caught up</span>
        <span class="h-px w-12 bg-zinc-800" />
      </div>
      <p class="text-xs text-zinc-800 mt-2">
        <a href={`${base}/calendar`} class="hover:text-zinc-600 transition-colors">View full calendar →</a>
      </p>
    </div>

    <script id="dashboard-events-data" type="application/json" set:html={JSON.stringify(allEvents)} />

  </main>
</Layout>

<script>
  import { isPlaceholderTime } from '../lib/time';
  import { downloadWeekendShareCard, getWeekendShareCardData } from '../lib/share-card';
  import { safeJsonParse } from '../lib/client-utils';

  const allEvents = safeJsonParse(
    document.getElementById('dashboard-events-data')?.textContent ?? '[]',
    []
  );

  (window as any).__rtAllEvents = allEvents;

  function renderWeekendShare() {
    const summary = document.getElementById('weekend-share-summary');
    const button = document.getElementById('weekend-share-btn') as HTMLButtonElement | null;
    const buttonLabel = document.getElementById('weekend-share-btn-label');
    const slot = document.getElementById('weekend-share-slot');
    if (!summary || !button || !buttonLabel || !slot) return;

    const data = getWeekendShareCardData(allEvents);
    if (!data) {
      slot.classList.add('hidden');
      return;
    }

    slot.classList.remove('hidden');
    summary.textContent = `${data.rangeLabel} • ${data.eventCount} events • ${data.sessionCount} sessions`;

    button.disabled = false;
    if (button.dataset.loading !== 'true') {
      buttonLabel.textContent = 'Weekend Card';
    }
  }

  // ── Client-side staleness fix ──
  // Labels (Today/Tomorrow) are baked at build time; race sessions may have
  // passed since the last deploy. This runs on page load and tab-focus to
  // move finished events to Recent and correct stale headings.
  function refreshDashboard() {
    const now = new Date();

    // 1. Move events whose race session has started to the Recent grid
    const recentGrid   = document.getElementById('recent-events');
    const recentSection = document.getElementById('recent-section');
    const mainWrappers = document.querySelectorAll<HTMLElement>(
      '.week-group .event-card-wrapper[data-race-utc]'
    );
    let moved = 0;
    mainWrappers.forEach(wrapper => {
      const raceUtc = wrapper.getAttribute('data-race-utc') ?? '';
      if (!raceUtc || isPlaceholderTime(raceUtc)) return;
      if (new Date(raceUtc) < now) {
        recentGrid?.appendChild(wrapper);
        moved++;
      }
    });

    // 2. Remove week sections that became empty after moving events
    document.querySelectorAll<HTMLElement>('.week-group').forEach(section => {
      if (section.getAttribute('data-lazy-group') === 'true') return; // lazy sections keep their shape
      if (section.querySelectorAll('.event-card-wrapper').length === 0) {
        section.remove();
      }
    });

    // 3. Show Recent section and update its count if we moved anything
    if (moved > 0 && recentSection && recentGrid) {
      recentSection.style.display = '';
      const count = recentGrid.querySelectorAll('[data-series]').length;
      const countSpan = document.querySelector<HTMLElement>('#recent-toggle span:last-of-type');
      if (countSpan) countSpan.textContent = `Recent (${count})`;
    }

    // 4. Update stale Today/Tomorrow headings — sections store data-week-date
    document.querySelectorAll<HTMLElement>('[data-week-date]').forEach(section => {
      const dateStr = section.getAttribute('data-week-date');
      if (!dateStr) return;
      const heading = section.querySelector('h2');
      if (!heading) return;

      const eventDate = new Date(dateStr + 'T12:00:00Z');
      const today = new Date(); today.setHours(0, 0, 0, 0);
      const diffDays = Math.floor((eventDate.getTime() - today.getTime()) / 86400000);

      let label: string;
      if (diffDays < 0) return;        // fully past — leave it (or it'll be empty and removed)
      else if (diffDays === 0) label = 'Today';
      else if (diffDays === 1) label = 'Tomorrow';
      else if (diffDays <= 7)  label = 'This week';
      else if (diffDays <= 14) label = 'Next week';
      else label = eventDate.toLocaleDateString('en', { month: 'long', year: 'numeric' });

      // Only touch the heading if the label actually changed
      const current = section.getAttribute('data-week-section');
      if (current === label) return;

      section.setAttribute('data-week-section', label);
      // Replace the first text node in h2 (the label text)
      const textNode = [...heading.childNodes].find(
        n => n.nodeType === Node.TEXT_NODE && (n.textContent ?? '').trim().length > 0
      );
      if (textNode) textNode.textContent = label;
    });
  }

  function initWeekendShare() {
    const button = document.getElementById('weekend-share-btn') as HTMLButtonElement | null;
    const buttonLabel = document.getElementById('weekend-share-btn-label');
    if (!button || !buttonLabel) return;

    renderWeekendShare();

    if (button.dataset.bound === 'true') return;
    button.dataset.bound = 'true';

    button.addEventListener('click', () => {
      if (button.disabled || button.dataset.loading === 'true') return;

      button.dataset.loading = 'true';
      button.disabled = true;
      buttonLabel.textContent = 'Preparing';

      try {
        const downloaded = downloadWeekendShareCard(allEvents);
        buttonLabel.textContent = downloaded ? 'Saved' : 'Unavailable';
      } catch {
        buttonLabel.textContent = 'Try again';
      } finally {
        window.setTimeout(() => {
          delete button.dataset.loading;
          renderWeekendShare();
        }, 900);
      }
    });
  }

  function initDashboard() {
    initWeekendShare();

    // ── Recent toggle ──
    const toggle  = document.getElementById('recent-toggle');
    const panel   = document.getElementById('recent-events');
    const chevron = document.getElementById('recent-chevron');
    if (toggle && panel && chevron) {
      toggle.addEventListener('click', () => {
        const open = !panel.classList.contains('hidden');
        panel.classList.toggle('hidden', open);
        chevron.style.transform = open ? '' : 'rotate(90deg)';
      });
    }

    // ── Lazy load ──
    const sentinel = document.getElementById('lazy-sentinel');
    const skeleton = document.getElementById('lazy-skeleton');
    const endMsg   = document.getElementById('lazy-end');
    const lazyGroups = [...document.querySelectorAll<HTMLElement>('[data-lazy-group="true"]')];

    if (!sentinel) return;

    if (lazyGroups.length === 0) {
      endMsg?.classList.remove('hidden');
      sentinel.remove();
      return;
    }

    let loading = false;

    function revealNextGroup() {
      if (loading) return;

      const group = lazyGroups.shift();
      if (!group) {
        skeleton?.classList.add('hidden');
        endMsg?.classList.remove('hidden');
        sentinel?.remove();
        return;
      }

      loading = true;
      skeleton?.classList.remove('hidden');

      // Small delay so the skeleton is actually visible — feels smooth
      setTimeout(() => {
        // Show the group
        group.style.display = '';
        group.removeAttribute('data-lazy-group');

        // Stagger card entrance animations
        const cards = group.querySelectorAll<HTMLElement>('.event-card-wrapper');
        cards.forEach((card, i) => {
          card.style.animationDelay = `${i * 55}ms`;
          card.classList.add('card-enter');
        });

        skeleton?.classList.add('hidden');
        loading = false;
      }, 280);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) revealNextGroup();
      },
      { rootMargin: '300px' } // trigger 300px before sentinel enters view
    );

    observer.observe(sentinel);
  }

  initDashboard();
  refreshDashboard();
  renderWeekendShare();
  document.addEventListener('astro:after-swap', () => { initDashboard(); refreshDashboard(); renderWeekendShare(); });
  // Re-check when the user comes back to the tab (e.g. phone sleep or alt-tab)
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) {
      refreshDashboard();
      renderWeekendShare();
    }
  });
</script>
