---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RaceTrack — Motorsport Event Tracker">
  <main class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">RaceTrack</h1>
    <p class="text-zinc-400 mb-8">All motorsport events. One dashboard.</p>

    <section class="mb-8">
      <h2 class="text-xl font-semibold mb-4">Upcoming Events</h2>
      <p class="text-zinc-500">No data yet — run <code class="bg-zinc-800 px-2 py-1 rounded text-sm">npm run fetch-data</code> to populate.</p>
    </section>
  </main>
</Layout>
