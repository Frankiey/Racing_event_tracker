---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import SeriesFilter from '../components/SeriesFilter.astro';
import Countdown from '../components/Countdown.astro';
import SeriesBadge from '../components/SeriesBadge.astro';
import { getRaceSession, isPlaceholderTime, countryFlag } from '../lib/time';
import { SERIES_LIST, getSeriesMeta } from '../lib/series';
import type { RaceEvent } from '../lib/types';

import upcomingData from '../../data/gold/upcoming.json';
import calendarData from '../../data/gold/calendar.json';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const now = new Date();
const SEASON_YEAR = now.getFullYear();
const upcoming = (upcomingData as any).events as RaceEvent[];
const allEvents = (calendarData as any).events as RaceEvent[];

// Find the next race session across all series
const nextRace = upcoming
  .map(e => ({ event: e, session: getRaceSession(e.sessions) }))
  .filter(x => x.session && !isPlaceholderTime(x.session.startTimeUTC) && new Date(x.session.startTimeUTC) > now)
  .sort((a, b) => new Date(a.session!.startTimeUTC).getTime() - new Date(b.session!.startTimeUTC).getTime())[0];

// Season stats per series: total rounds and rounds completed
const seasonStats = new Map<string, { total: number; done: number }>();
for (const e of allEvents) {
  const s = seasonStats.get(e.seriesId) ?? { total: 0, done: 0 };
  s.total++;
  if (new Date(e.dateEnd + 'T23:59:59Z') < now) s.done++;
  seasonStats.set(e.seriesId, s);
}

// Sort chronologically (upcoming.json is grouped by series, not sorted by date)
const sortedUpcoming = [...upcoming].sort((a: any, b: any) => a.dateStart.localeCompare(b.dateStart));

// Build full event list with a per-series cap (no total cap — lazy load handles paging)
const MAX_PER_SERIES = 6;
const seriesCounts = new Map<string, number>();
const dashboardEvents: typeof upcoming = [];
for (const event of sortedUpcoming) {
  const count = seriesCounts.get(event.seriesId) ?? 0;
  if (count >= MAX_PER_SERIES) continue;
  seriesCounts.set(event.seriesId, count + 1);
  dashboardEvents.push(event);
}
dashboardEvents.sort((a: any, b: any) => a.dateStart.localeCompare(b.dateStart));

// Group by week label
function getWeekLabel(event: any): string {
  // Use the race session start time for past-detection if available;
  // fall back to dateEnd for events with placeholder/missing race times.
  const raceSession = getRaceSession(event.sessions);
  const isPast = (raceSession && !isPlaceholderTime(raceSession.startTimeUTC))
    ? new Date(raceSession.startTimeUTC) < now
    : new Date(event.dateEnd + 'T23:59:59Z') < now;
  if (isPast) return '__recent__';

  const eventDate = new Date(event.dateStart + 'T12:00:00Z');
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  const diffDays = Math.floor((eventDate.getTime() - today.getTime()) / 86400000);
  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return 'Tomorrow';
  if (diffDays <= 7) return 'This week';
  if (diffDays <= 14) return 'Next week';
  return eventDate.toLocaleDateString('en', { month: 'long', year: 'numeric' });
}

// Track the first event's dateStart per section so client-side JS can recompute labels
const grouped = new Map<string, typeof dashboardEvents>();
const groupFirstDate = new Map<string, string>();
for (const event of dashboardEvents) {
  const label = getWeekLabel(event);
  if (!grouped.has(label)) {
    grouped.set(label, []);
    groupFirstDate.set(label, event.dateStart);
  }
  grouped.get(label)!.push(event);
}

const recentEvents = grouped.get('__recent__') ?? [];
const visibleGroups = [...grouped.entries()].filter(([k]) => k !== '__recent__');

// First 2 groups render visible; the rest are in the DOM but hidden — revealed by lazy loader
const INITIAL_GROUPS = 2;

const nextCircuitFlag = nextRace ? countryFlag(nextRace.event.circuit.countryCode) : '';
const nextRaceMeta = nextRace ? getSeriesMeta(nextRace.event.seriesId) : null;
---

<Layout title="RaceTrack — Motorsport Event Tracker" currentPath={`${base}/`}>
  <main class="max-w-5xl mx-auto px-4 py-8">

    <!-- ── Hero countdown ── -->
    {nextRace && (
      <div class="relative mb-8 rounded-2xl overflow-hidden border border-zinc-700/40">
        <div class="absolute inset-0 bg-gradient-to-br from-zinc-900 via-zinc-900 to-zinc-950" />
        <div
          class="absolute inset-0 opacity-[0.07]"
          style={`background: radial-gradient(ellipse 80% 60% at 80% 50%, ${nextRaceMeta?.color ?? '#e10600'}, transparent)`}
        />
        <div class="absolute left-0 inset-y-0 w-1 rounded-l-2xl" style={`background: ${nextRaceMeta?.color ?? '#e10600'};`} />

        <div class="relative px-6 py-6 sm:px-8 sm:py-7">
          <div class="flex flex-col sm:flex-row sm:items-center gap-5 sm:gap-8">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2.5 mb-3 flex-wrap">
                <SeriesBadge seriesId={nextRace.event.seriesId} size="md" />
                <span class="text-xs text-zinc-500 font-mono">Round {nextRace.event.round}</span>
                <span
                  class="text-[10px] px-2 py-0.5 rounded-full font-bold uppercase tracking-widest"
                  style={`background-color: ${nextRaceMeta?.color ?? '#e10600'}20; color: ${nextRaceMeta?.color ?? '#e10600'}`}
                >
                  Next Race
                </span>
              </div>
              <h2 class="text-2xl sm:text-3xl font-black text-zinc-100 tracking-tight leading-none mb-2">
                {nextRace.event.eventName}
              </h2>
              <p class="flex items-center gap-2 text-sm text-zinc-400">
                {nextCircuitFlag && <span class="text-xl leading-none">{nextCircuitFlag}</span>}
                <span class="font-medium">{nextRace.event.circuit.name}</span>
                {nextRace.event.circuit.country && (
                  <>
                    <span class="text-zinc-700">·</span>
                    <span class="text-zinc-500">{nextRace.event.circuit.country}</span>
                  </>
                )}
              </p>
            </div>

            <div class="sm:text-right shrink-0">
              <Countdown
                targetUTC={nextRace.session!.startTimeUTC}
                label="Race starts in"
              />
            </div>
          </div>
        </div>
      </div>
    )}

    <!-- ── Season stats ── -->
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-3">
        <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600">{SEASON_YEAR} Season</h2>
        <span class="h-px flex-1 bg-zinc-800/80" />
        <a href={`${base}/calendar`} class="text-[10px] text-zinc-600 hover:text-zinc-400 transition-colors uppercase tracking-widest">
          Full calendar →
        </a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
        {SERIES_LIST.filter(s => seasonStats.has(s.id)).map(s => {
          const stats = seasonStats.get(s.id)!;
          const pct = stats.total > 0 ? Math.round((stats.done / stats.total) * 100) : 0;
          return (
            <a
              href={`${base}/series/${s.id}`}
              class="group flex flex-col gap-2 bg-zinc-900/60 border border-zinc-800 hover:border-zinc-700 rounded-xl p-3 transition-colors"
            >
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-1.5">
                  <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${s.color}`} />
                  <span class="text-xs font-bold text-zinc-300">{s.shortLabel}</span>
                </div>
                <span class="text-[11px] font-mono text-zinc-500 tabular-nums">{stats.done}/{stats.total}</span>
              </div>
              <div class="h-1 rounded-full bg-zinc-800 overflow-hidden">
                <div class="h-full rounded-full transition-all" style={`width: ${pct}%; background-color: ${s.color};`} />
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <!-- ── Filter ── -->
    <SeriesFilter />

    <!-- Recent — collapsed by default -->
    {recentEvents.length > 0 && (
      <div id="recent-section" class="mb-6">
        <button
          id="recent-toggle"
          class="w-full flex items-center gap-3 text-[10px] font-bold text-zinc-700 uppercase tracking-widest hover:text-zinc-500 transition-colors group"
        >
          <svg id="recent-chevron" class="w-3 h-3 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          <span>Recent ({recentEvents.length})</span>
          <span class="h-px flex-1 bg-zinc-800/40 group-hover:bg-zinc-700/40 transition-colors" />
        </button>
        <div id="recent-events" class="hidden mt-3 grid gap-2.5">
          {recentEvents.map(event => (
            <div data-series={event.seriesId}>
              <EventCard event={event} />
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- ── Event groups — first INITIAL_GROUPS visible, rest lazy ── -->
    {visibleGroups.map(([weekLabel, weekEvents], i) => (
      <section
        class="week-group mb-8"
        data-week-section={weekLabel}
        data-week-date={groupFirstDate.get(weekLabel) ?? ''}
        data-lazy-group={i >= INITIAL_GROUPS ? 'true' : undefined}
        style={i >= INITIAL_GROUPS ? 'display:none' : undefined}
      >
        <h2 class="text-[10px] font-bold text-zinc-600 uppercase tracking-widest mb-3 flex items-center gap-3">
          {weekLabel}
          <span class="h-px flex-1 bg-zinc-800/60" />
          <span class="text-zinc-700">{weekEvents.length}</span>
        </h2>
        <div class="grid gap-2.5">
          {weekEvents.map(event => (
            <div
              data-series={event.seriesId}
              class="event-card-wrapper"
              data-race-utc={getRaceSession(event.sessions)?.startTimeUTC ?? ''}
            >
              <EventCard
                event={event}
                highlight={nextRace?.event.id === event.id}
              />
            </div>
          ))}
        </div>
      </section>
    ))}

    {visibleGroups.length === 0 && recentEvents.length === 0 && (
      <div class="text-center py-16 text-zinc-600">
        <p class="text-4xl mb-4">🏁</p>
        <p class="font-semibold mb-1 text-zinc-500">No upcoming events</p>
        <p class="text-sm">Run <code class="bg-zinc-800 text-zinc-300 px-2 py-1 rounded">npm run fetch-data</code> to populate.</p>
      </div>
    )}

    <!-- ── Lazy load sentinel + skeleton + end ── -->
    <div id="lazy-sentinel" class="h-1" />

    <div id="lazy-skeleton" class="hidden space-y-2.5 mb-8" aria-hidden="true">
      {[0, 1, 2].map(i => (
        <div
          class="skeleton-card rounded-xl border border-zinc-800/50"
          style={`height: 112px; animation-delay: ${i * 120}ms`}
        />
      ))}
    </div>

    <div id="lazy-end" class="hidden text-center py-10 text-zinc-700">
      <div class="inline-flex items-center gap-3">
        <span class="h-px w-12 bg-zinc-800" />
        <span class="text-xs uppercase tracking-widest font-semibold">All caught up</span>
        <span class="h-px w-12 bg-zinc-800" />
      </div>
      <p class="text-xs text-zinc-800 mt-2">
        <a href={`${base}/calendar`} class="hover:text-zinc-600 transition-colors">View full calendar →</a>
      </p>
    </div>

  </main>
</Layout>

<script>
  import { isPlaceholderTime } from '../lib/time';

  // ── Client-side staleness fix ──
  // Labels (Today/Tomorrow) are baked at build time; race sessions may have
  // passed since the last deploy. This runs on page load and tab-focus to
  // move finished events to Recent and correct stale headings.
  function refreshDashboard() {
    const now = new Date();

    // 1. Move events whose race session has started to the Recent grid
    const recentGrid   = document.getElementById('recent-events');
    const recentSection = document.getElementById('recent-section');
    const mainWrappers = document.querySelectorAll<HTMLElement>(
      '.week-group .event-card-wrapper[data-race-utc]'
    );
    let moved = 0;
    mainWrappers.forEach(wrapper => {
      const raceUtc = wrapper.getAttribute('data-race-utc') ?? '';
      if (!raceUtc || isPlaceholderTime(raceUtc)) return;
      if (new Date(raceUtc) < now) {
        recentGrid?.appendChild(wrapper);
        moved++;
      }
    });

    // 2. Remove week sections that became empty after moving events
    document.querySelectorAll<HTMLElement>('.week-group').forEach(section => {
      if (section.getAttribute('data-lazy-group') === 'true') return; // lazy sections keep their shape
      if (section.querySelectorAll('.event-card-wrapper').length === 0) {
        section.remove();
      }
    });

    // 3. Show Recent section and update its count if we moved anything
    if (moved > 0 && recentSection && recentGrid) {
      recentSection.style.display = '';
      const count = recentGrid.querySelectorAll('[data-series]').length;
      const countSpan = document.querySelector<HTMLElement>('#recent-toggle span:last-of-type');
      if (countSpan) countSpan.textContent = `Recent (${count})`;
    }

    // 4. Update stale Today/Tomorrow headings — sections store data-week-date
    document.querySelectorAll<HTMLElement>('[data-week-date]').forEach(section => {
      const dateStr = section.getAttribute('data-week-date');
      if (!dateStr) return;
      const heading = section.querySelector('h2');
      if (!heading) return;

      const eventDate = new Date(dateStr + 'T12:00:00Z');
      const today = new Date(); today.setHours(0, 0, 0, 0);
      const diffDays = Math.floor((eventDate.getTime() - today.getTime()) / 86400000);

      let label: string;
      if (diffDays < 0) return;        // fully past — leave it (or it'll be empty and removed)
      else if (diffDays === 0) label = 'Today';
      else if (diffDays === 1) label = 'Tomorrow';
      else if (diffDays <= 7)  label = 'This week';
      else if (diffDays <= 14) label = 'Next week';
      else label = eventDate.toLocaleDateString('en', { month: 'long', year: 'numeric' });

      // Only touch the heading if the label actually changed
      const current = section.getAttribute('data-week-section');
      if (current === label) return;

      section.setAttribute('data-week-section', label);
      // Replace the first text node in h2 (the label text)
      const textNode = [...heading.childNodes].find(
        n => n.nodeType === Node.TEXT_NODE && (n.textContent ?? '').trim().length > 0
      );
      if (textNode) textNode.textContent = label;
    });
  }

  function initDashboard() {
    // ── Recent toggle ──
    const toggle  = document.getElementById('recent-toggle');
    const panel   = document.getElementById('recent-events');
    const chevron = document.getElementById('recent-chevron');
    if (toggle && panel && chevron) {
      toggle.addEventListener('click', () => {
        const open = !panel.classList.contains('hidden');
        panel.classList.toggle('hidden', open);
        chevron.style.transform = open ? '' : 'rotate(90deg)';
      });
    }

    // ── Lazy load ──
    const sentinel = document.getElementById('lazy-sentinel');
    const skeleton = document.getElementById('lazy-skeleton');
    const endMsg   = document.getElementById('lazy-end');
    const lazyGroups = [...document.querySelectorAll<HTMLElement>('[data-lazy-group="true"]')];

    if (!sentinel) return;

    if (lazyGroups.length === 0) {
      endMsg?.classList.remove('hidden');
      sentinel.remove();
      return;
    }

    let loading = false;

    function revealNextGroup() {
      if (loading) return;

      const group = lazyGroups.shift();
      if (!group) {
        skeleton?.classList.add('hidden');
        endMsg?.classList.remove('hidden');
        sentinel?.remove();
        return;
      }

      loading = true;
      skeleton?.classList.remove('hidden');

      // Small delay so the skeleton is actually visible — feels smooth
      setTimeout(() => {
        // Show the group
        group.style.display = '';
        group.removeAttribute('data-lazy-group');

        // Stagger card entrance animations
        const cards = group.querySelectorAll<HTMLElement>('.event-card-wrapper');
        cards.forEach((card, i) => {
          card.style.animationDelay = `${i * 55}ms`;
          card.classList.add('card-enter');
        });

        skeleton?.classList.add('hidden');
        loading = false;
      }, 280);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) revealNextGroup();
      },
      { rootMargin: '300px' } // trigger 300px before sentinel enters view
    );

    observer.observe(sentinel);
  }

  initDashboard();
  refreshDashboard();
  document.addEventListener('astro:after-swap', () => { initDashboard(); refreshDashboard(); });
  // Re-check when the user comes back to the tab (e.g. phone sleep or alt-tab)
  document.addEventListener('visibilitychange', () => { if (!document.hidden) refreshDashboard(); });
</script>
