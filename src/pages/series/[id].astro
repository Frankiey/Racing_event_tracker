---
import Layout from '../../layouts/Layout.astro';
import EventCard from '../../components/EventCard.astro';
import SeriesBadge from '../../components/SeriesBadge.astro';
import { SERIES_LIST, getSeriesMeta } from '../../lib/series';
import { getRaceSession, isPlaceholderTime, isPastEvent } from '../../lib/time';

import type { EventFeed } from '../../lib/types';
import calendarData from '../../../data/gold/calendar.json';

export function getStaticPaths() {
  return SERIES_LIST.map(s => ({ params: { id: s.id } }));
}

const { id } = Astro.params;
const meta = getSeriesMeta(id);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allEvents = (calendarData as EventFeed).events.filter(e => e.seriesId === id);
const now = new Date();

const doneEvents = allEvents.filter(e => isPastEvent(e.dateEnd, e.sessions));
const upcomingEvents = allEvents.filter(e => !isPastEvent(e.dateEnd, e.sessions));

// Next race for this series
const nextRace = upcomingEvents
  .map(e => ({ event: e, session: getRaceSession(e.sessions) }))
  .filter(x => x.session && !isPlaceholderTime(x.session.startTimeUTC))
  .sort((a, b) => new Date(a.session!.startTimeUTC).getTime() - new Date(b.session!.startTimeUTC).getTime())[0];

// Group all events by month
const grouped = new Map<string, typeof allEvents>();
for (const event of allEvents) {
  const label = new Date(event.dateStart + 'T12:00:00Z').toLocaleDateString('en', { month: 'long', year: 'numeric' });
  if (!grouped.has(label)) grouped.set(label, []);
  grouped.get(label)!.push(event);
}

const progressPct = allEvents.length > 0 ? Math.round((doneEvents.length / allEvents.length) * 100) : 0;
---

<Layout title={`RaceTrack — ${meta.label}`} currentPath={`${base}/series/${id}`}>
  <main class="max-w-5xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="mb-8">
      <a href={`${base}/`} class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors mb-4 inline-block">
        ← Back to dashboard
      </a>
      <div class="flex items-start gap-4 flex-wrap">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-3 mb-2">
            <SeriesBadge seriesId={id} size="md" />
          </div>
          <h1 class="text-3xl font-bold tracking-tight mb-1">{meta.label}</h1>
          <p class="text-zinc-400 text-sm">2026 Season Schedule</p>
        </div>

        <!-- Season progress -->
        <div class="bg-zinc-900/60 border border-zinc-800 rounded-xl p-4 min-w-[200px]">
          <div class="flex items-center justify-between text-xs text-zinc-400 mb-2">
            <span>Season progress</span>
            <span class="font-mono text-zinc-300">{doneEvents.length} / {allEvents.length}</span>
          </div>
          <div class="h-2 rounded-full bg-zinc-800 overflow-hidden">
            <div
              class="h-full rounded-full transition-all"
              style={`width: ${progressPct}%; background-color: ${meta.color};`}
            />
          </div>
          <div class="flex justify-between text-[10px] text-zinc-600 mt-1.5">
            <span>{doneEvents.length} done</span>
            <span>{upcomingEvents.length} remaining</span>
          </div>
          <button
            id="export-series-ics"
            class="mt-3 w-full text-xs text-zinc-500 hover:text-zinc-300 transition-colors border border-zinc-800 hover:border-zinc-600 rounded-lg px-3 py-1.5 flex items-center justify-center gap-1.5"
            data-series-id={id}
            data-series-label={meta.label}
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
            Export .ics
          </button>
        </div>
      </div>
    </div>

    <!-- Next race callout -->
    {nextRace && (
      <div class="mb-8 rounded-xl border p-4 flex items-center gap-4 flex-wrap" style={`border-color: ${meta.color}40; background-color: ${meta.color}08;`}>
        <div class="flex-1 min-w-0">
          <p class="text-xs font-semibold uppercase tracking-widest mb-1" style={`color: ${meta.color};`}>Next race</p>
          <p class="font-semibold text-zinc-100">{nextRace.event.eventName}</p>
          <p class="text-sm text-zinc-400">{nextRace.event.circuit.name}</p>
        </div>
        <div class="text-right">
          <p class="text-xs text-zinc-500 mb-0.5">Race</p>
          <time
            class="text-sm font-mono text-zinc-300 tabular-nums"
            datetime={nextRace.session!.startTimeUTC}
            data-local-time={nextRace.session!.startTimeUTC}
            data-format="datetime"
          >
            {new Date(nextRace.session!.startTimeUTC).toLocaleString('en', {
              month: 'short', day: 'numeric',
              hour: '2-digit', minute: '2-digit',
              hour12: false, timeZone: 'UTC',
            })} UTC
          </time>
        </div>
      </div>
    )}

    <!-- Event list grouped by month -->
    {[...grouped.entries()].map(([month, monthEvents]) => {
      const allPast = monthEvents.every(e => isPastEvent(e.dateEnd, e.sessions));
      return (
        <section class="mb-8">
          <h2 class:list={[
            'text-xs font-semibold uppercase tracking-widest mb-3 flex items-center gap-3',
            allPast ? 'text-zinc-700' : 'text-zinc-400',
          ]}>
            {month}
            <span class="h-px flex-1 bg-zinc-800" />
            <span class:list={['font-normal', allPast ? 'text-zinc-800' : 'text-zinc-600']}>{monthEvents.length}</span>
          </h2>
          <div class="grid gap-3">
            {monthEvents.map(event => (
              <EventCard event={event} />
            ))}
          </div>
        </section>
      );
    })}

    {allEvents.length === 0 && (
      <p class="text-zinc-500 text-center py-12">No events found for {meta.label}.</p>
    )}

    <script id="series-events-data" type="application/json" set:html={JSON.stringify(allEvents)} />
  </main>
</Layout>

<script>
  import { registerEvents } from '../../lib/event-client';
  import { exportEventsIcs } from '../../lib/ics';
  import { safeJsonParse } from '../../lib/client-utils';

  const events = safeJsonParse(
    document.getElementById('series-events-data')!.textContent!, []
  );

  registerEvents(events);

  const btn = document.getElementById('export-series-ics');
  if (btn) {
    btn.addEventListener('click', () => {
      const label = btn.dataset.seriesLabel ?? 'Series';
      exportEventsIcs(`RaceTrack ${label} 2026`, events);
    });
  }
</script>
