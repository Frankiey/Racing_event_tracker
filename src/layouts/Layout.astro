---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  currentPath?: string;
  fullWidth?: boolean;
  bare?: boolean;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { title, currentPath = `${base}/`, fullWidth = false, bare = false } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Motorsport event tracker — F1, MotoGP, IndyCar, WEC and more in one dashboard" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen">
    {!bare && <Nav currentPath={currentPath} />}
    <slot />
  </body>
</html>
